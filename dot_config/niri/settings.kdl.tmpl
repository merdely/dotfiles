// vim: set filetype=kdl :
// NOTE: Do not edit this file directly
// Use: chezmoi edit ~/.config/niri/settings.kdl

output "eDP-1" {
    position x=0 y=0
}

output "DP-1" {
    focus-at-startup
    position x=1920 y=0
}

output "HDMI-A-1" {
    position x=3840 y=0
}

workspace "1"       { open-on-output "DP-1";  }
workspace "Cameras" { open-on-output "eDP-1"; }
workspace "🗒️"      { open-on-output "eDP-1"; }

input {
    // keyboard { xkb { options "menu:super" ; }; }
    touchpad {
        dwt
        click-method "clickfinger"
        scroll-method "two-finger"
    }
    workspace-auto-back-and-forth
    focus-follows-mouse max-scroll-amount="49%"
}

layout {
    gaps 8
    focus-ring { off; }
    border {
        on
        width 2
    }
}

// Code to switch-or-launch:
// { spawn-sh "a=kitty;b=$a;id=$(niri msg -j windows | jq --arg a \"$a\" '[.[]|select(.app_id==$a).id]|min' 2>/dev/null);{ [[ -n \"$id\" ]] && niri msg action focus-window --id \"$id\"; } || gtk-launch \"$b\""; }
// a = the app_id (niri msg windows)
// b = the name of the launcher (ls /usr/share/applications)

binds {
    Mod+Return hotkey-overlay-title=null { spawn "true"; }
    Mod+D      hotkey-overlay-title=null { spawn "true"; }
    Mod+Apostrophe       hotkey-overlay-title="Idle Inhibit"     { spawn-sh "dms ipc call inhibit toggle"; }
    Mod+Ctrl+Alt+Shift+H hotkey-overlay-title=null               { focus-column-or-monitor-left; }
    Mod+Ctrl+Alt+Shift+L hotkey-overlay-title=null               { focus-column-or-monitor-right; }
    Mod+Semicolon        hotkey-overlay-title="Open RBW"         { spawn-sh "pgrep -u $LOGNAME -f '^(/?.*[p]ython .*)?rofi(-rbw| -markup-rows -dmenu)' && pkill -u $LOGNAME -f '^(/?.*[p]ython .*)?rofi(-rbw| -markup-rows -dmenu)' || rofi-rbw --use-notify-send"; }
    Mod+Shift+A          hotkey-overlay-title="Open Signal"      { spawn-sh "$HOME/.config/niri/scratchpad org.signal.Signal"; }
    // Must create a termfm.desktop in $HOME/.local/share/applications
    Mod+Shift+BracketLeft  hotkey-overlay-title="Terminal File Manager"  { spawn-sh "$HOME/.config/niri/scratchpad termfm"; }
    Mod+Shift+C          hotkey-overlay-title="Open Galculator"  { spawn-sh "pgrep -u $LOGNAME -x galculator && pkill -u $LOGNAME -x galculator || gtk-launch galculator"; }
    Mod+Shift+Q          hotkey-overlay-title="Open Logseq"      { spawn-sh "$HOME/.config/niri/scratchpad com.logseq.Logseq Logseq"; }
    // Must create a term-scratchpad.desktop in $HOME/.local/share/applications
    Mod+Shift+Return     hotkey-overlay-title="Scratch Terminal" { spawn-sh "$HOME/.config/niri/scratchpad term-scratchpad"; }
    Mod+Shift+Semicolon  hotkey-overlay-title="System Monitor"   { spawn-sh "$HOME/.config/niri/scratchpad htop"; }
    Mod+Shift+Apostrophe hotkey-overlay-title="GPU Monitor"      { spawn-sh "$HOME/.config/niri/scratchpad nvtop"; }
    Mod+Shift+Space hotkey-overlay-title="Clear Notifications"   { spawn-sh "dms ipc call notifications clearAll;dms ipc call notifications close"; }
    Mod+Shift+W          hotkey-overlay-title="Open SMS"         { spawn-sh "$HOME/.config/niri/scratchpad org.kde.kdeconnect.sms"; }
    Mod+Shift+X          hotkey-overlay-title="Cam Chooser"      { spawn-sh "pgrep -u $LOGNAME -f '[r]ofi -p View Camera' && pkill -u $LOGNAME -f '[r]ofi -p View Camera' || $HOME/.local/bin/cam-chooser"; }
    Mod+Shift+Z          hotkey-overlay-title="Open Bitwarden"   { spawn-sh "$HOME/.config/niri/scratchpad bitwarden Bitwarden"; }
    Mod+T                hotkey-overlay-title="Open Terminal"    { spawn-sh "${TERMINAL:-kitty}"; }
    XF86Tools            hotkey-overlay-title="Lock Screen"      { spawn-sh "dms ipc call lock lock && niri msg action power-off-monitors"; }
    Mod+Slash            hotkey-overlay-title="Niri Help"        { spawn-sh "pgrep -u $LOGNAME -f '^((/usr(/local)?)?/bin/)?[i]mv(-wayland)? -w niri_help' && pkill -u $LOGNAME -f '^((/usr(/local)?)?/bin/)?[i]mv(-wayland)? -w niri_help' || imv -w niri_help -W '300' -H '300' -r -n keymap_super.svg ~/Pictures/niri_help/*.svg"; }
    Mod+Ctrl+Slash       hotkey-overlay-title="Gen Niri Help"    { spawn-sh "dms keybinds show niri | env PATH=$PATH:$HOME/.local/bin $HOME/.config/niri/gen_keymaps -d -f -o ~/Pictures/niri_help"; }
}

// Open many apps maximized
window-rule {
    match app-id=r#"^(code-oss|chromium|fr\.handbrake\.ghb|FreeTube|io\.github\.celluloid_player\.Celluloid|io\.github\.ungoogled_software\.ungoogled_chromium|gimp|labwc|LM Studio|obsidian|vlc|Tor Browser)$"#
    match app-id=r#"^(firefox|librewolf)"#
    open-maximized true
}

// Open VM windows maxiumized
window-rule {
    match app-id="virt-manager"
    exclude title="^Virtual Machine Manager$"
    open-maximized true
}

// Make Niri help look good at 1920x1080
// May need to override in local.kdl
window-rule {
    match app-id=r#"imv"# title=r#"niri_help"#
    open-floating true
    min-width 1700
    min-height 900
    max-width 1700
    max-height 900
    default-floating-position x=110 y=70 relative-to="top-left"
}

// Highlight casted windows
window-rule {
    match is-window-cast-target=true
    border {
        width 6
        active-color "#f38ba8"
        inactive-color "#7d0d2d"
    }
}

// Open scratchpad apps floating
window-rule {
    match app-id=r#"^Bitwarden|com\.logseq\.Logseq|Logseq|org\.kde\.kdeconnect\.sms|org\.signal\.Signal|htop|htop-earth|nvtop|nvtop-earth|term-scratchpad|termfm$"#
    open-maximized false
    open-floating true
}

// Start scratchpad apps in scratchpad workspace
window-rule {
    match app-id=r#"^Bitwarden|com\.logseq\.Logseq|Logseq|org\.kde\.kdeconnect\.sms|org\.signal\.Signal|htop|htop-earth|nvtop|nvtop-earth|term-scratchpad|termfm$"# at-startup=true
    open-on-workspace "🗒️"
    open-maximized true
    open-floating false
    open-focused false
}

// Camera rules
window-rule {
    match app-id=r#"^mpvcam"#
    match title=r#"^mpvcam"#
    // open-fullscreen true
    // open-focused false
    open-maximized true
    open-on-workspace "Cameras"
}

window-rule {
    match app-id=r#"^mpvcammulti garagecam"#
    match title=r#"^mpvcammulti garagecam"#
    open-maximized false
    open-on-workspace "Cameras"
    open-floating true
    default-column-width { proportion 0.50; }
    default-window-height { proportion 0.50; }
    default-floating-position x=0 y=0 relative-to="top-left"
}

