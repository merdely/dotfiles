#!/usr/bin/env bash
# vim: set filetype=sh :
# NOTE: Do not edit this file directly
# Use: chezmoi edit ~/.config/niri/scratchpad

progname=${0##*/}
progname=${progname%.sh}
usage() {
  echo "usage: $progname [-h] [-R] [-c] [-m] command|ACTIVE [windowclass] [title]"
  echo "         By default, $progname uses gtk-launch"
  echo "         With -c, $progname looks for a command string \"foo --bar --baz\""
  echo "         With -R, $progname will NOT resize windows to 90% when unminimizing"
  echo "         With -m, $progname will start the program minimized"
  echo "Note: -m only works on niri for now"
  exit "${1:-0}"
}

TMPFILES=()
trap 'rm -Rf "${TMPFILES[@]}"' EXIT
trap 'exit 1' INT TERM

niri_floating_ws_name="${niri_floating_ws_name:-🗒️}"

declare -A resize_app
resize_height=90%
resize_width=$resize_height
resize_app[galculator]="640|480"
# shellcheck disable=SC1091
[[ -r "$HOME"/.config/wm-minimize.conf ]] && source "$HOME"/.config/wm-minimize.conf

mode=desktop
resize=true
start_minimized=false

while getopts ":hcRm" opt; do
  case "$opt" in
    c) mode=cmdline ;;
    R) resize=false ;;
    m) start_minimized=true ;;
    *) usage ;;
  esac
done
shift $(( OPTIND - 1 ))

(( $# == 0 )) && usage 1

cmd=$1
appid=$1
[[ -n "$2" ]] && appid=$2
[[ -n "$3" ]] && title=$3

toggle_minimize() {
  niri_floating_ws=$(niri msg -j workspaces | \
    jq -r --arg n "$niri_floating_ws_name" '.[] | select(.name==$n) | .id')
  if [[ -z "$2" ]]; then
    win_info=$(niri msg -j windows | jq -r --arg c "$1" '.[] | select(.app_id==$c)')
  else
    win_info=$(niri msg -j windows | jq -r --arg c "$1" --arg t "$2" '.[] | select(.app_id==$c and .title==$t)')
  fi
  app_id=$(echo "$win_info" | jq -r '.id')
  is_focused=$(echo "$win_info" | jq -r '.is_focused')

  app_ws=$(echo "$win_info" | jq -r '.workspace_id')
  cur_ws=$(niri msg -j focused-window | jq -r '.workspace_id')
  cur_mon=$(niri msg -j focused-output | jq -r '.name')

  # Don't do anything inside the Float WS
  if [[ "${cur_ws:-0}" == "${niri_floating_ws:-1}" && "${app_ws:-0}" == "${niri_floating_ws:-1}" ]]; then
    [[ "${is_focused:-true}" == false ]] && niri msg action focus-window --id "$app_id"
    return 0
  fi

  # If the app is not focused but in this workspace, bring to front
  # if [[ "${is_focused:-true}" == false && "$app_ws" == "$cur_ws" ]]; then
  #   niri msg action focus-window --id "$app_id"
  #   return 0
  # fi

  if [[ "${app_ws:-0}" == "${niri_floating_ws:-1}" ]] || \
        [[ "${cur_ws:-0}" != "${niri_floating_ws:-1}" && "${app_ws:-0}" != "${cur_ws:-1}" ]]; then
    # If Window in Floating Workspace or Workspace not current workspace, move it here
    niri msg action move-window-to-floating --id "$app_id"
    if [[ -n "${new_height[$app_id]}" ]]; then
      niri msg action set-window-height --id "$app_id" "${resize_app[$1]#*|}"
      niri msg action set-window-width --id "$app_id" "${resize_app[$1]%|*}"
    elif "$resize"; then
      niri msg action set-window-height --id "$app_id" "$resize_height"
      niri msg action set-window-width --id "$app_id" "$resize_width"
      sleep .1
    fi
    niri msg action move-window-to-monitor --id "$app_id" "$cur_mon"
    niri msg action focus-window --id "$app_id"
    niri msg action center-window --id "$app_id"
  else
    niri msg action move-window-to-workspace --focus false --window-id "$app_id" "$niri_floating_ws_name"
    niri msg action move-window-to-tiling --id "$app_id"
    niri msg action set-window-width --id "$app_id" 100%
    [[ "${cur_ws:-0}" == "${niri_floating_ws:-1}" ]] && niri msg action focus-window --id "$app_id"
    return 0
  fi
}

do_exec() {
  if [[ "$mode" == desktop ]]; then
    echo "gtk-launch $*"
  else
    echo "$*"
  fi
}

run_cmd() {
  if $start_minimized && [[ -n "$2" ]]; then
    tmpconfig=$(mktemp)
    TMPFILES+=("$tmpconfig")
    printf "window-rule {\n%b%b%b%b%b}\n" \
      "$([ -n "$2" ] && echo "    match app-id=r#\"$2\"#\n" || echo "")" \
      "$([ -n "$3" ] && echo "    match title=r#\"$3\"#\n" || echo "")" \
      "    open-floating false\n" \
      "    open-focused false\n" \
      "    open-on-workspace \"$niri_floating_ws_name\"\n" >> "$tmpconfig"
    echo "include \"$tmpconfig\"" >> "$HOME"/.config/niri/config.kdl
  fi
  niri_floating_ws=$(niri msg -j workspaces | jq -r --arg n "$niri_floating_ws_name" '.[] | select(.name==$n) | .id')
  niri msg action spawn -- $(do_exec "$1")
  cur_ws=$(niri msg -j focused-window | jq -r '.workspace_id')
  unset app_id
  count=0
  while [[ -z "$app_id" ]] && (( count <= 100 )); do
    app_id=$(niri msg -j windows | jq -r --arg c "$2" '.[] | select(.app_id==$c) | .id')
    [[ -z "$app_id" ]] && (( count++ )) && sleep .1
  done
  if "$start_minimized" && [[ -r "$tmpconfig" ]]; then
    sed -i "/^include \"${tmpconfig//\//\\\/}\"$/d" "$HOME"/.config/niri/config.kdl
  fi
  if (( count >= 100 )); then
    echo "Warning: Could not get window id" >&2
  else
    if [[ "${cur_ws:-0}" == "${niri_floating_ws:-1}" ]]; then
      niri msg action move-window-to-tiling --id "$app_id"
      niri msg action set-window-width --id "$app_id" 100%
      return 0
    fi
    if [[ -n "${new_height[$app_id]}" ]]; then
      niri msg action set-window-height --id "$app_id" "${resize_app[$1]#*|}"
      niri msg action set-window-width --id "$app_id" "${resize_app[$1]%|*}"
    elif "$resize"; then
      niri msg action set-window-height --id "$app_id" "$resize_height"
      niri msg action set-window-width --id "$app_id" "$resize_width"
      sleep .1
    fi
    niri msg action center-window --id "$app_id"
  fi
}

isrunning() {
  niri msg -j windows | jq -r --arg c "$1" '.[] | select(.app_id==$c) | .app_id' | grep -qE "^${1}$"
}

if [[ "$cmd" == ACTIVE ]]; then
  niri_floating_ws=$(niri msg -j workspaces | \
    jq -r --arg n "$niri_floating_ws_name" '.[] | select(.name==$n) | .id')
  if [[ $(niri msg -j focused-window | jq -r .is_floating) == false ]]; then
    echo "Warning: The active window is not a floating window... not minimizing" >&2
    exit 0
  fi
  app_id=$(niri msg -j focused-window | jq '.id')
  app_ws=$(niri msg -j focused-window | jq '.workspace_id')
  #cur_mon=$(niri msg -j focused-output | jq -r '.name')
  if [[ "${app_ws:-0}" == "${niri_floating_ws:-1}" ]]; then
    niri msg action move-window-up-or-to-workspace-up
    niri msg action move-window-to-floating --id "$app_id"
    # niri msg action move-window-to-monitor --id $app_id $cur_mon
    niri msg action focus-window --id "$app_id"
    if [[ -n "${new_height[$app_id]}" ]]; then
      niri msg action set-window-height --id "$app_id" "${resize_app[$1]#*|}"
      niri msg action set-window-width --id "$app_id" "${resize_app[$1]%|*}"
    elif "$resize"; then
      niri msg action set-window-height --id "$app_id" "$resize_height"
      niri msg action set-window-width --id "$app_id" "$resize_width"
      sleep .1
    fi
    niri msg action center-window --id "$app_id"
  else
    niri msg action move-window-to-workspace --focus false --window-id "$app_id" "$niri_floating_ws_name"
    niri msg action move-window-to-tiling --id "$app_id"
    niri msg action set-window-width --id "$app_id" 100%
  fi
else
  if isrunning "$appid"; then
    toggle_minimize "$appid" "$title"
  else
    run_cmd "$cmd" "$appid" "$title"
  fi
fi

