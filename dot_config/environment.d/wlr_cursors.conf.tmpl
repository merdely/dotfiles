# vim: set filetype=conf :
# NOTE: Do not edit this file directly
# Use: chezmoi edit ~/.config/environment.d/wlr_cursors.conf

# Force compositor to render cursor (VMs flip cursor without it)

{{- $virt_output := output "sh" "-c" "systemd-detect-virt 2>/dev/null || true" | trim }}
{{- if eq $virt_output "kvm" }}
WLR_NO_HARDWARE_CURSORS=1
{{- else }}
# WLR_NO_HARDWARE_CURSORS=1
{{- end }}
