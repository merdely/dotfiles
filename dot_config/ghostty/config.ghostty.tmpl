# vim: set filetype=ghostty :
# NOTE: Do not edit this file directly
# Use: chezmoi edit ~/.config/ghostty/config.ghostty

background = 000000
background-opacity = 0.8
font-family = DejaVuSansM Nerd Font Mono
font-size = 11
theme = Kitty Default

# Import a file named $hostname.ghostty (leading "?" means to ignore non-existent file)
config-file = ?{{ .chezmoi.hostname }}.ghostty

