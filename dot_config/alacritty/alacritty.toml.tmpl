# vim: set filetype=toml :
# NOTE: Do not edit this file directly
# Use: chezmoi edit ~/.config/alacritty/alacritty.toml

# This file imports:
#  - settings.toml: so settings can be overwritten by other imports
#  - hyper.toml: a theme I like
#  - $hostname.toml (does nothing if file does not exist)

[general]
live_config_reload = true
import = [
  "settings.toml",
  "hyper.toml",
  "{{ .chezmoi.hostname }}.toml"
]
