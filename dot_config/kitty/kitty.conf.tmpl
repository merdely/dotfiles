# vim: set filetype=kitty :
# NOTE: Do not edit this file directly
# Use: chezmoi edit ~/.config/kitty/kitty.conf

font_family               DejaVuSansM Nerd Font Mono
font_size                 10.0
background_opacity        0.8
close_on_child_death      yes
confirm_os_window_close   0
clipboard_control         write-clipboard write-primary read-clipboard read-primary
cursor_blink_interval     0
cursor_shape              block
cursor_trail              1
enable_audio_bell         no
enabled_layouts           splits, stack, grid
scrollback_lines          10000
shell_integration         no-cursor no-title
# visual_bell_color         white
visual_bell_duration      0.1
window_padding_width      2
update_check_interval     0
mouse_map                 left click ungrabbed
mouse_map                 ctrl+left click ungrabbed mouse_handle_click selection link prompt

# Global key bindings
## Split Management
# Vertical
map                             ctrl+b>% launch --location=vsplit --cwd=current
map --when-focus-on var:in_tmux ctrl+b>% no-op
# Horizontal
map                             ctrl+b>shift+apostrophe launch --location=hsplit --cwd=current
map --when-focus-on var:in_tmux ctrl+b>shift+apostrophe no-op

# Split Navigation
map                             ctrl+b>ctrl+h neighboring_window left
map --when-focus-on var:in_tmux ctrl+b>ctrl+h no-op

map                             ctrl+b>ctrl+j neighboring_window down
map --when-focus-on var:in_tmux ctrl+b>ctrl+j no-op

map                             ctrl+b>ctrl+k neighboring_window up
map --when-focus-on var:in_tmux ctrl+b>ctrl+k no-op

map                             ctrl+b>ctrl+l neighboring_window right
map --when-focus-on var:in_tmux ctrl+b>ctrl+l no-op

# Split Management
map                       ctrl+shift+b>r start_resizing_window


map                       alt+shift+\ launch --location=vsplit --cwd=current
map                       alt+shift+- launch --location=hsplit --cwd=current

map                       alt+a neighboring_window left
map                       alt+left neighboring_window left
map                       alt+s neighboring_window down
map                       alt+down neighboring_window down
map                       alt+w neighboring_window up
map                       alt+up neighboring_window up
map                       alt+d neighboring_window right
map                       alt+right neighboring_window right
map                       alt+shift+a move_window left
map                       alt+shift+left move_window left
map                       alt+shift+s move_window down
map                       alt+shift+down move_window down
map                       alt+shift+w move_window up
map                       alt+shift+up move_window up
map                       alt+shift+d move_window right
map                       alt+shift+right move_window right
map                       alt+shift+ctrl+h resize_window narrower
map                       alt+shift+ctrl+j resize_window shorter
map                       alt+shift+ctrl+k resize_window taller
map                       alt+shift+ctrl+l resize_window wider

{{/*
  # Include file named $hostname.conf (I think it prints an error if it does not exist, but it's benign)
*/ -}}
include $HOME/.config/kitty/{{ .chezmoi.hostname }}.conf

