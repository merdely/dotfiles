noblacklist ${HOME}/.config/electron-flags.conf
whitelist ${HOME}/.config/electron-flags.conf
read-only ${HOME}/.config/electron-flags.conf

# Directories that Code can access
whitelist ${HOME}/src
whitelist ${HOME}/git

noblacklist ${HOME}/.vscode-shared
whitelist ${HOME}/.vscode-shared
noblacklist ${HOME}/.vscode-oss-shared
whitelist ${HOME}/.vscode-oss-shared
