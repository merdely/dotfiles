" ===============================
" Paths
" ===============================
if isdirectory(expand('~/.config/vim'))
  let g:vim_config_dir = expand('~/.config/vim')
  let g:vim_data_dir   = expand('~/.local/share/vim')
  let g:vim_state_dir  = expand('~/.local/state/vim')
  let g:vim_cache_dir  = expand('~/.cache/vim')
elseif isdirectory(expand('~/.vim'))
  let g:vim_config_dir = expand('~/.vim')
  let g:vim_data_dir   = expand('~/.vim')
  let g:vim_state_dir  = expand('~/.vim')
  let g:vim_cache_dir  = expand('~/.vim')
else
  let g:vim_config_dir = ''
  let g:vim_data_dir   = ''
  let g:vim_state_dir  = expand('~/.local/state/vim')
  let g:vim_cache_dir  = expand('~/.cache/vim')
endif

" Define vim directories
let &directory   = g:vim_cache_dir . '/swapfiles'
let &backupdir   = g:vim_cache_dir . '/backup'
let &undodir     = g:vim_state_dir . '/undo'
let &viminfofile = g:vim_state_dir . '/viminfo'

" create directories that do not exist
for s:dir in [ g:vim_data_dir, g:vim_state_dir, g:vim_cache_dir, &directory, &backupdir, &undodir ]
  if s:dir != '' && !isdirectory(s:dir)
    call mkdir(s:dir, 'p', 0700)
  endif
endfor

" add trailing slashes for full path of the file being edited (with % for /)
let &directory = &directory . '//'
let &backupdir = &backupdir . '//'

" Runtime paths (works whether vimrc is ~/.vimrc or ~/.config/vim/vimrc)
let &packpath = g:vim_data_dir . ',' . &packpath
let &runtimepath = g:vim_config_dir
      \ . ',' . &runtimepath
      \ . ',' . g:vim_data_dir
      \ . ',' . g:vim_config_dir . '/after'
      \ . ',' . g:vim_config_dir . '/ftplugin'
      \ . ',' . g:vim_config_dir . '/spell'

