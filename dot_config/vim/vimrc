" Toggle split layout (requires exactly 2 windows)
function! ToggleSplitLayout() abort
  if winnr('$') != 2
    echohl WarningMsg | echo 'Layout toggle requires exactly 2 windows' | echohl None
    return
  endif

  " Get the row position of each window
  let l:win1_row = win_screenpos(1)[0]
  let l:win2_row = win_screenpos(2)[0]

  " If both windows are on the same row → vertical split (side by side)
  " If they differ in row → horizontal split (stacked)
  if l:win1_row == l:win2_row
    " Currently vertical, switch to horizontal
    windo wincmd K
  else
    " Currently horizontal, switch to vertical
    windo wincmd H
  endif
endfunction
nnoremap <leader>st :call ToggleSplitLayout()<CR>

