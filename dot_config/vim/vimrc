let s:has_statusline_plugin = 0
if (exists('g:plugs') && has_key(g:plugs, 'lightline.vim') && isdirectory(g:plugs['lightline.vim'].dir))
      \ || exists('g:loaded_airline')
      \ || exists('g:loaded_lightline')
  let s:has_statusline_plugin = 1
