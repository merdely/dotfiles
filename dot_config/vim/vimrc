      return "\uf15b "
    endif
    return get(l:icons, l:ft, "\uf15b ") . l:ft
  endfunction

  " File size (kept for potential future use)
  function! StatuslineFileSize() abort
    let l:size = getfsize(expand('%'))
    if l:size < 0
      return ''
    endif
    if l:size < 1024
      return "\uf016 " . l:size . 'B '
    elseif l:size < 1024 * 1024
      return "\uf016 " . printf('%.1fK', l:size / 1024.0) . ' '
    else
      return "\uf016 " . printf('%.1fM', l:size / 1024.0 / 1024.0) . ' '
    endif
  endfunction

  " Mode indicator
  function! StatuslineModeIcon() abort
    let l:modes = {
          \ 'n':    'NORMAL',
          \ 'i':    'INSERT',
          \ 'v':    'VISUAL',
          \ 'V':    'V-LINE',
          \ "\x16": 'V-BLOCK',
          \ 'c':    'COMMAND',
          \ 's':    'SELECT',
          \ 'S':    'S-LINE',
          \ "\x13": 'S-BLOCK',
          \ 'R':    'REPLACE',
          \ 'r':    'REPLACE',
          \ '!':    'SHELL',
          \ 't':    'TERMINAL',
          \ }
    return get(l:modes, mode(), "\uf059 " . mode())
  endfunction

  function! s:SetActiveStatusline() abort
    let &l:statusline =
          \ ' %#StatusLineBold#%{StatuslineModeIcon()}%#StatusLine# '
          \ . "\ue0b1"
          \ . '%{StatuslineGitBranch()}'
          \ . ' %f %h%m%r'
          \ . '%='
          \ . "%{&fenc!=''?&fenc:&enc}"
          \ . ' ' . "\ue0b3"
          \ . ' %{&fileformat}'
          \ . ' ' . "\ue0b3"
          \ . ' %{&filetype}'
          \ . ' ' . "\ue0b3"
          \ . ' %P'
          \ . ' ' . "\ue0b3"
          \ . ' %l:%c '
  endfunction

  " Note: inactive uses StatuslineFileType() with icon; active uses &filetype
  " without — adjust if you want them consistent
  function! s:SetInactiveStatusline() abort
    let &l:statusline =
          \ ' %f %h%m%r '
          \ . "\ue0b1"
          \ . ' %='
          \ . '%{StatuslineFileType()} '
          \ . "\ue0b3"
          \ . ' %P '
          \ . "\ue0b3"
          \ . ' %l:%c '
  endfunction
  augroup UserStatusline
    autocmd!
    autocmd WinEnter,BufEnter * call s:SetActiveStatusline()
    autocmd WinLeave,BufLeave * call s:SetInactiveStatusline()
  augroup END
  set laststatus=2
endif
