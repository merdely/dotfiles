" ===============================
" PATHS
" ===============================
if isdirectory(expand('~/.config/vim'))
  let g:vim_config_dir = expand('~/.config/vim')
  let g:vim_data_dir   = expand('~/.local/share/vim')
  let g:vim_state_dir  = expand('~/.local/state/vim')
  let g:vim_cache_dir  = expand('~/.cache/vim')
elseif isdirectory(expand('~/.vim'))
  let g:vim_config_dir = expand('~/.vim')
  let g:vim_data_dir   = expand('~/.vim')
  let g:vim_state_dir  = expand('~/.vim')
  let g:vim_cache_dir  = expand('~/.vim')
else
  let g:vim_config_dir = ''
  let g:vim_data_dir   = ''
  let g:vim_state_dir  = expand('~/.local/state/vim')
  let g:vim_cache_dir  = expand('~/.cache/vim')
endif

" Define vim directories
let &directory   = g:vim_cache_dir . '/swapfiles'
let &backupdir   = g:vim_cache_dir . '/backup'
let &undodir     = g:vim_state_dir . '/undo'
let &viminfofile = g:vim_state_dir . '/viminfo'

" create directories that do not exist
for s:dir in [ g:vim_data_dir, g:vim_state_dir, g:vim_cache_dir, &directory, &backupdir, &undodir ]
  if s:dir != '' && !isdirectory(s:dir)
    call mkdir(s:dir, 'p', 0700)
  endif
endfor

" add trailing slashes for full path of the file being edited (with % for /)
let &directory = &directory . '//'
let &backupdir = &backupdir . '//'

" Runtime paths (works whether vimrc is ~/.vimrc or ~/.config/vim/vimrc)
if g:vim_config_dir != ''
  let &packpath = g:vim_data_dir . ',' . &packpath
  let &runtimepath = g:vim_config_dir
        \ . ',' . &runtimepath
        \ . ',' . g:vim_data_dir
        \ . ',' . g:vim_config_dir . '/after'
        \ . ',' . g:vim_config_dir . '/ftplugin'
        \ . ',' . g:vim_config_dir . '/spell'
endif

" ===============================
" COLORSCHEME DEFAULTS
" ===============================
" Highlight customizations moved into a ColorScheme autocmd so they persist
" when a plugin colorscheme (e.g. catppuccin) loads and re-fires the event,
" instead of being silently clobbered at startup.
function! s:ApplyHighlights() abort
  highlight CursorLine     cterm=NONE term=NONE gui=NONE ctermbg=1  guibg=#081e2f
  highlight ColorColumn    ctermbg=1  guibg=#182e3f
  highlight SignColumn     term=NONE  gui=NONE   cterm=NONE  ctermbg=NONE guibg=NONE
  highlight CursorLineSign term=NONE  gui=NONE   cterm=NONE  ctermbg=NONE guibg=#081e2f
  highlight CursorLineNr   term=NONE  gui=NONE   cterm=bold  ctermfg=3    guifg=Grey75 guibg=#081e2f
  highlight StatusLine     gui=NONE   cterm=NONE guifg=#c0c0d0 ctermfg=250 guibg=#081e2f ctermbg=17
  highlight StatusLineBold gui=bold   cterm=bold guifg=#c0c0d0 ctermfg=250 guibg=#081e2f ctermbg=17
  highlight StatusLineNC   gui=NONE   cterm=NONE guifg=#606070 ctermfg=242 guibg=#081e2f ctermbg=17
  highlight HighlightedyankRegion guifg=#011627 guibg=#ffcb8b

  highlight Normal         ctermbg=NONE guibg=NONE
  highlight NormalNC       ctermbg=NONE guibg=NONE
  highlight EndOfBuffer    ctermbg=NONE guibg=NONE
endfunction

call s:ApplyHighlights()
autocmd ColorScheme * call s:ApplyHighlights()

