" Make file executable
function! MakeExecutable() abort
  let l:file = expand('%:p')
  if empty(l:file)
    echoerr 'No filename'
    return
  endif
  write

  if has('unix')
    call system('chmod +x ' . shellescape(l:file))
    if v:shell_error
      echoerr 'chmod +x failed'
      return
    endif
  else
    " Non-Unix fallback: set execute bits directly via setfperm
    let l:perm = getfperm(l:file)
    call setfperm(l:file, l:perm[:1] . 'x' . l:perm[3:4] . 'x' . l:perm[6:7] . 'x')
  endif
  edit!
  echom 'Made ' . l:file . ' executable (' . getfperm(l:file) . ')'
endfunction
nnoremap <silent> <leader>x :call MakeExecutable()<CR>

