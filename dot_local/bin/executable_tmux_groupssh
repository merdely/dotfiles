#!/bin/sh

progname=${0##*/}
progname=${progname%.sh}
usage() {
  echo "usage: $progname [-s] [-u] [-4|-6] [-h|-v] [-t|-eh|-ev|-mh|-mv] HOST..."
  echo "        --help: This help text"
  echo "        -s: synchronize panes"
  echo "        -u: don't use known_hosts"
  echo "        -4: use ipv4"
  echo "        -6: use ipv6"
  echo "        -t: Use tiled layout (default)"
  echo "        -eh: Use even-horizontal layout"
  echo "        -ev: Use even-vertical layout"
  echo "        -mh: Use main-horizontal layout"
  echo "        -mv: Use main-vertical layout"
  echo "        -h: horizontal split"
  echo "        -v: vertical split"
  echo "        HOST1 [HOST2 [HOST3...[HOSTn]]]"
  exit 1
}

for a in $*; do [ $a = --help ] && usage; done

sync=false
unset mode
unset split
unset khosts
unset foursix

while getopts ":su46emthv" opt; do
  case ${opt} in
    s)
      sync=true
      ;;
    u)
      khosts="-o GlobalKnownHostsFile=/dev/null -o UserKnownHostsFile=/dev/null -o StrictHostKeyChecking=no"
      ;;
    4)
      foursix="-4"
      ;;
    6)
      foursix="-6"
      ;;
    e)
      mode=even
      ;;
    m)
      mode=main
      ;;
    t)
      mode=tiled
      unset split
      ;;
    h)
      [ -z "${@:$OPTIND:1}" -o "$(echo ${@:$OPTIND:1} | cut -c1)" = - ] && usage
      split="-horizontal"
      ;;
    v)
      split="-vertical"
      ;;
    *)
      usage
      ;;
  esac
done
shift $((OPTIND -1))

hostname=$(tmux display -p "#{host}")

[ -z "$mode" ] && mode=tiled
[ -n "$split" ] && [ $mode = tiled ] && mode=even
[ -z "$1" ] && exit 0

# Check if ansible command is installed
ansible=false
command -v ansible > /dev/null 2>&1 && ansible=true

# Replace commas with spaces and reset script arguments
group=$(echo "$@" | sed 's/,/ /g')
set -- $group

# Set the group name to the first argument
group_name=$1

# Expand any ansible groups into individual hosts
unset hostlist
for host in $group; do
  # Check if host is in DNS
  host "$host" > /dev/null
  ret1=$?

  # Check if host is in ssh_config
  awk '/^Host /{for(i=2;i<=NF;i++){if($i~/[*?!]/)continue;if($i~/^([0-9]{1,3}\.){3}[0-9]{1,3}$/)continue;printf " %s ",$i}}' $HOME/.ssh/config | grep -q " $host "
  ret2=$?

  # If we have ansible, host is not in DNS and host is not in ssh_config, expand ssh group
  if $ansible && [ $ret1 != 0 -a $ret2 != 0 ] || [ $host = cribl ]; then
    ansible_list="$(ansible $host --list-hosts | awk 'NR>1{printf " %s",$1}')"
  fi

  # If an ansible list was expanded, use it, otherwise, just use $host
  if [ -n "${ansible_list# }" ]; then
    hostlist="${hostlist# } ${ansible_list# }"
  else
    hostlist="${hostlist# } $host"
  fi
done
# Strip leading space
hostlist=${hostlist# }

count=0
for host in $hostlist; do
  if [ $count = 0 ]; then
    # If $host is the tmux server, just open a new window, otherwise ssh
    if [ "$host" = "$hostname" ] || [ "$host" = "${hostname%%.*}" ]; then
      window=$(tmux new-window -n "$host")
    else
      window=$(tmux new-window -n "$host" ssh ${foursix:+$foursix }${khosts:+$khosts }$host)
    fi
  else
    # If $host is the tmux server, just create a split, otherwise ssh
    if [ "$host" = "$hostname" ] || [ "$host" = "${hostname%%.*}" ]; then
      tmux split-window -t:$window.{bottom-right}
    else
      tmux split-window -t:$window.{bottom-right} ssh ${foursix:+$foursix }${khosts:+$khosts }$host
    fi
    tmux select-layout -t:$window.0 $mode$split
  fi
  count=$((count+1))
done

if [ $count -gt 1 ]; then
  if [ $count -eq 2 ]; then
    mode=${mode:-even}
    split=${split:-horizontal}
  elif [ $((count % 2)) -eq 0 -o $count -gt 4 ]; then
    unset split
    mode=tiled
  fi
  tmux select-layout -t:$window.0 $mode$split

  $sync && tmux setw -t:$window.0 synchronize-panes && \
                   tmux setw -F -t:$window.0 pane-active-border-style "#{?pane_synchronized,fg=red,fg=green}"
fi

# Specific group handling
case "$group_name" in
  hass)
    w=${window#*:}
    sleep .5
    tmux split-window -vl 77% -t "$w" ssh ${foursix:+$foursix }${khosts:+$khosts }hass
    tmux send -t "${w%.*}.0" "ha core logs --follow" Enter
    tmux select-pane -t ":${w%.*}.{bottom-right}"
    unset w
    ;;
esac

exit 0
