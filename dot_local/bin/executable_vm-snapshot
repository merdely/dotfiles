#!/usr/bin/env bash

usage() {
  echo "usage: ${0##*} [Options] VM_NAME [SNAPSHOT_NAME]"
  echo "Options:"
  echo " -h          : This help text"
  echo " -d DESCR    : Snapshot description (default: none)"
  exit "${1:-0}"
}

vm=""
snapshot="snapshot1"
description=""
disks=()
while getopts ":hd:" opt; do
  case $opt in
    d) description=$OPTARG ;;
    h) usage ;;
    :) echo "-$OPTARG requires an argument" ; exit 1 ;;
    \?) echo "Unknown option: -$OPTARG" ; exit 1 ;;
  esac
done
shift $(( OPTIND - 1 ))

(( $# == 0 )) && usage 1
vm=$1
shift
snapshot="$*"

mapfile -t disks < <(virsh domblklist "$vm" --details | awk '$1=="file" && $2=="disk" {print $3}')

disk_opt=()
for disk in "${disks[@]}"; do
  disk_opt+=(--diskspec "$disk,snapshot=external")
done
if (( ${#disk_opt[@]} == 0 )); then
  echo "Error: Could not determine disks for $vm" >&2
  exit 1
fi

if [[ -n "$description" ]]; then
  desc=(--description "$description")
fi

[[ ! -d /var/lib/libvirt/qemu/snapshot/"$vm" ]] &&
  mkdir -m 775 -p /var/lib/libvirt/qemu/snapshot/"$vm"

virsh snapshot-create-as "$vm" --name "$snapshot" "${desc[@]}" --atomic "${disk_opt[@]}" \
  --memspec /var/lib/libvirt/qemu/snapshot/"$vm"/"$snapshot"-memory,snapshot=external

