#!/usr/bin/env bash

if which hostname > /dev/null 2>&1; then
  hostname=$(hostname)
else
  hostname=$(hostnamectl hostname)
fi
hostname=${hostname%%.*}

if [ $hostname != mercury ] && which brightnessctl &> /dev/null \
  && brightnessctl -l -c backlight &> /dev/null; then
  brightnessctl -r &> /dev/null
  true
elif which gammastep &> /dev/null; then
  pkill -u $LOGNAME -x gammastep
else
  echo "Error: Cannot find program to undim screen"
fi

