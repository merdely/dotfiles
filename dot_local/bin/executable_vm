#!/usr/bin/env bash
# vim: set filetype=sh :
# NOTE: Do not edit this file directly
# Use: chezmoi edit ~/.local/bin/vm

clone_usage() {
  echo "usage: ${0##*} clone [Options] SRC_VM DEST_VM"
  echo
  echo "Options:"
  echo " -h     : This help text"
  echo " -u     : Connect to hypervisor with libvirt user/session URI (default: system URI)"
  echo " -c URI : Connect to hypervisor with libvirt URI (e.g.: -c qemu:///otherhost.example.com)"
  echo " -s     : Start new VM after clone"
  echo " -S     : Start new VM after clone and connect to the console"
  echo
  echo "To use -c with -l, specify -c/-u first"
  exit "${1:-0}"
}

clone() {
  command -v virt-clone &>/dev/null || { echo "Error: virt-clone is required for this program" >&2 ; exit 1 ; }

  local connect=(--connect qemu:///system) start=false opts=()
  local OPTIND=1 OPTARG="" opt=""
  while getopts ":huc:sS" opt; do
    case $opt in
      u) connect=(--connect qemu:///session) ;;
      c) connect=(--connect "$OPTARG") ;;
      s) start=true ;;
      S) start=true ; opts+=(--console) ;;
      h) clone_usage ;;
      :) echo "-$OPTARG requires an argument" ; exit 1 ;;
      \?) echo "Unknown option: -$OPTARG" ; exit 1 ;;
    esac
  done
  shift $(( OPTIND - 1 ))

  virt-clone "${connect[@]}" --auto-clone --original "$1" --name "$2"
  $start && virsh start "$2" "${opts[@]}" || true
}

create_usage() {
  echo "usage: ${0##*/} create [Options]"
  echo
  echo "Options:"
  echo " -h                 : This help text"
  echo " -A                 : Arch Linux"
  echo " -D                 : Debian"
  echo " -O                 : OpenBSD"
  echo " -Q                 : Oracle Enterprise Linux 9"
  echo " -n NAME            : Name for the VM (default: ${1:-vm_type})"
  echo " -r SIZE            : RAM SIZE in MB (default: $vm_ram MB)"
  echo " -v COUNT           : VCPU COUNT (default $vm_vcpus)"
  echo " -d SIZE            : Disk SIZE in GB (default: $vm_disk GB)"
  echo " -i ISO             : ISO path (default: latest iso in $iso_path for vm_type)"
  echo " -g                 : Disable GPU mode"
  echo " -T                 : Test mode (print command instead of running it)"
  echo
  echo "One of -A, -D, -O, -Q is required"
  exit "${1:-0}"
}

create() {
  command -v virt-install &>/dev/null || { echo "Error: virt-install is required for this program" >&2 ; exit 1 ; }

  local vm_name=$1 vm_ram=8192 vm_vcpus=2 vm_disk=20 vm_iso="" iso_path=/share/software/Isos

  # shellcheck disable=1091
  [[ -r "$HOME"/.config/newvmrc ]] && source "$HOME"/.config/newvmrc

  local testmode="" vm_type=""
  local gpu_mode=(
    "--graphics" "spice,listen=none"
    "--graphics" "egl-headless,gl.rendernode=/dev/dri/by-path/pci-0000:00:02.0-render"
    "--video" "model=virtio,accel3d=yes"
  )
  local OPTIND=1 OPTARG="" opt=""
  while getopts ":hADOQn:r:v:d:i:gT" opt; do
    case $opt in
      A) vm_type=arch ;;
      D) vm_type=debian ;;
      O) vm_type=openbsd ;;
      Q) vm_type=ol9 ;;
      n) vm_name=$OPTARG ;;
      r) vm_ram=$OPTARG ;;
      v) vm_vcpus=$OPTARG ;;
      d) vm_disk=$OPTARG ;;
      i) vm_iso=$OPTARG ;;
      g) gpu_mode=("--video" "virtio") ;;
      T) testmode="echo" ;;
      h) create_usage ;;
      :) echo "-$OPTARG requires an argument" ; exit 1 ;;
      \?) echo "Unknown option: -$OPTARG" ; exit 1 ;;
    esac
  done
  shift $(( OPTIND - 1 ))

  [[ -z "$vm_type" ]] && { echo "Error: -A, -D, -O, -Q required" ; create_usage 1 ; }

  # Get system information
  local sys_ram="" sys_proc="" sys_disk=""
  sys_ram=$(free -m | awk '/^Mem:/{print $2}')
  if [[ ! "$sys_ram" =~ ^[1-9][0-9]*$ ]]; then
    echo "Error: Could not determine system RAM"
    exit 1
  fi
  if command -v nproc &> /dev/null; then
    sys_proc=$(nproc)
  elif [[ -r /proc/cpuinfo ]]; then
    sys_proc=$(grep -Ec "^processor[[:space:]]*:")
  fi
  if [[ ! "$sys_proc" =~ ^[1-9][0-9]*$ ]]; then
    echo "Error: Could not determine system cpu count"
    exit 1
  fi
  sys_disk=$(df -k --output=avail /var/lib/libvirt/images | tail -n1)
  if [[ ! "$sys_disk" =~ ^[1-9][0-9]*$ ]]; then
    echo "Error: Could not determine system disk availability"
    exit 1
  fi

  # Validate RAM
  if [[ ! "$vm_ram" =~ ^[1-9][0-9]*$ ]]; then
    echo "Error: RAM must be numeric ($vm_ram)"
    exit 1
  elif (( vm_ram > sys_ram - 5 )); then
    echo "Error: Not enough system RAM for $vm_ram MB ($sys_ram MB on system)"
    exit 1
  elif (( vm_ram > sys_ram * 2 / 3 )); then
    echo "Warning: Using more than 2/3 system ram ($vm_ram of $sys_ram MB)"
  fi

  # Validate CPU count
  if [[ ! "$vm_vcpus" =~ ^[1-9][0-9]*$ ]]; then
    echo "Error: VCPU count must be numeric ($vm_vcpus)"
    exit 1
  elif (( vm_vcpus > sys_proc )); then
    echo "Error: VCPU count greater than system cpu count ($vm_vcpus > $sys_proc)"
    exit 1
  fi

  # Validate Disk size
  if [[ ! "$vm_disk" =~ ^[1-9][0-9]*$ ]]; then
    echo "Error: Disk size must be numeric ($vm_disk)"
    exit 1
  elif (( vm_disk > sys_disk - 20 )); then
    echo "Error: Disk size of $vm_disk GB uses too much of $sys_disk GB available"
    exit 1
  fi

  # Validate ISO directory
  local iso_found=false iso=""
  for iso in "$iso_path"/*.iso; do
    iso_found=true
    break
  done
  [[ ! -d "$iso_path" ]] && { echo "Error: Could not find $iso_path" ; exit 1 ; }
  if ! $iso_found; then
    echo "Error: Could not find any ISO files in $iso_path"
    exit 1
  fi

  local os_variant="" vm_label="" os_search="" iso_search="" install_flags=()
  case "$vm_type" in
    arch)
      vm_label="Arch Linux"
      os_search=archlinux
      iso_search="archlinux-*.iso"
      vm_iso=$(get_iso "$iso_search" "$vm_iso")
      install_flags=(
        "--location" "$vm_iso,kernel=arch/boot/x86_64/vmlinuz-linux,initrd=arch/boot/x86_64/initramfs-linux.img"
        "--extra-args" "console=ttyS0,115200"
        "--extra-args" "archisodevice=/dev/sr0"
      )
      ;;
    debian)
      vm_label=Debian
      os_search=debian
      iso_search="debian-*-netinst.iso"
      vm_iso=$(get_iso "$iso_search" "$vm_iso")
      install_flags=(
        "--location" "$vm_iso"
        "--extra-args" "console=ttyS0,115200n8 --- console=ttyS0,115200n8"
      )
      ;;
    openbsd)
      vm_label=OpenBSD
      os_search=openbsd
      iso_search="openbsd-install*-serial.iso"
      vm_iso=$(get_iso "$iso_search" "$vm_iso")
      install_flags=( "--cdrom" "$vm_iso" )
      ;;
    ol9)
      vm_label="Oracle Enterprise Linux"
      os_search='ol9\\.'
      iso_search="OracleLinux-R9-U*-x86_64-boot-uek.iso"
      vm_iso=$(get_iso "$iso_search" "$vm_iso")
      install_flags=(
        "--location" "$vm_iso,kernel=images/pxeboot/vmlinuz,initrd=images/pxeboot/initrd.img"
        "--extra-args" "console=ttyS0,115200"
        "--extra-args" "inst.text"
      )
      ;;
    *)
      echo "Error: Invalid VM Type (-A for Arch, -D for Debian, -O for OpenBSD, -Q for Oracle Linux 9)" >&2
      exit 1
      ;;
  esac

  os_variant=$(get_os_variant "$os_search")
  echo "Installing a new $vm_label VM: name=$vm_name, ram=$vm_ram, disk=$vm_disk, cpu=$vm_vcpus"

  $testmode virt-install --connect "${VIRSH_DEFAULT_CONNECT_URI:-qemu:///system}" \
    --os-variant "$os_variant" --name "$vm_name" --ram "$vm_ram" --vcpus "$vm_vcpus" \
    --disk path=/var/lib/libvirt/images/"$vm_name".qcow2,size="$vm_disk",format=qcow2 \
    --vsock cid.auto=yes --boot uefi "${gpu_mode[@]}" --autoconsole text \
    "${install_flags[@]}"
}

delete_usage() { echo "usage: ${0##*} delete [-h] [-f] VM_TO_DELETE.." ; exit "${1:-0}" ; }

delete() {
  local force=false pronoun=its vmlabel=VM vm="" REPLY=""
  local OPTIND=1 OPTARG="" opt=""
  while getopts ":hf" opt; do
    case $opt in
      f) force=true ;;
      h) delete_usage ;;
      :) echo "-$OPTARG requires an argument" ; exit 1 ;;
      \?) echo "Unknown option: -$OPTARG" ; exit 1 ;;
    esac
  done
  shift $(( OPTIND - 1 ))

  (( $# > 1 )) && { pronoun=their ; vmlabel=VMs ; }

  if ! "$force"; then
    read -rp "Really delete $vmlabel ($*) and $pronoun storage? [yN] "
    if [[ ! "$REPLY" =~ ^(YES|Yes|yes|Y|y|1)$ ]]; then
      echo "Not deleting $1"
      exit
    fi
    echo
  fi

  for vm in "$@"; do
    if ! grep -q "shut off" < <(virsh domstate "$vm"); then
      virsh destroy "$vm"
    fi
    virsh undefine "$vm" --nvram --remove-all-storage
  done
}

list_usage() {
  echo "usage: ${0##*} list [Options]"
  echo
  echo "Options:"
  echo " -h: This help text"
  echo " -a: Print all VMs (default action)"
  echo " -A: Print VMs set to autostart"
  echo " -r: Print running VMs"
  echo " -o: Print off/stopped VMs"
  echo " -p: Print paused VMs"
  echo " -s: Print VMs with snapshot"
  echo " -S: Print VMs without snapshot"
  echo " -i: List DHCP IP Address List"
  echo "     Pass a network name on the command line (default: 'default')"
  exit "${1:-0}"
}

list() {
  local opts=() mode=list
  local OPTIND=1 OPTARG="" opt=""
  while getopts ":haAropsSi" opt; do
    case $opt in
      a) [[ " ${opts[*]} " != *" --all "* ]] && opts+=(--all) ;;
      A) [[ " ${opts[*]} " != *" --autostart "* ]] && opts+=(--autostart) ;;
      r) [[ " ${opts[*]} " != *" --state-running "* ]] && opts+=(--state-running) ;;
      o) [[ " ${opts[*]} " != *" --state-shutoff "* ]] && opts+=(--state-shutoff) ;;
      p) [[ " ${opts[*]} " != *" --state-paused "* ]] && opts+=(--state-paused) ;;
      s) [[ " ${opts[*]} " != *" --with-snapshot "* ]] && opts+=(--with-snapshot) ;;
      S) [[ " ${opts[*]} " != *" --without-snapshot "* ]] && opts+=(--without-snapshot) ;;
      i) mode=ip ;;
      h) list_usage ;;
      :) echo "-$OPTARG requires an argument" ; exit 1 ;;
      \?) echo "Unknown option: -$OPTARG" ; exit 1 ;;
    esac
  done
  shift $(( OPTIND - 1 ))
  (( ${#opts[@]} == 0 )) && opts=(--all)

  if [[ "$mode" == ip ]]; then
    virsh net-dhcp-leases "${1:-default}"
    exit
  fi

  virsh list "${opts[@]}"
}

reboot_usage() {
  echo "usage: ${0##*} reboot [Options] VM_NAME"
  echo
  echo "Options:"
  echo " -h          : This help text"
  exit "${1:-0}"
}

reboot() {
  local OPTIND=1 OPTARG="" opt=""
  while getopts ":h" opt; do
    case $opt in
      h) reboot_usage ;;
      :) echo "-$OPTARG requires an argument" ; exit 1 ;;
      \?) echo "Unknown option: -$OPTARG" ; exit 1 ;;
    esac
  done
  shift $(( OPTIND - 1 ))

  (( $# == 0 )) && reboot_usage 1

  virsh reboot "$1"
}

reset_usage() {
  echo "usage: ${0##*} reset [Options] VM_NAME"
  echo
  echo "Options:"
  echo " -h          : This help text"
  exit "${1:-0}"
}

reset() {
  local OPTIND=1 OPTARG="" opt=""
  while getopts ":h" opt; do
    case $opt in
      h) reset_usage ;;
      :) echo "-$OPTARG requires an argument" ; exit 1 ;;
      \?) echo "Unknown option: -$OPTARG" ; exit 1 ;;
    esac
  done
  shift $(( OPTIND - 1 ))

  (( $# == 0 )) && reset_usage 1

  virsh reset "$1"
}

snapshot_usage() {
  echo "usage: ${0##*} snapshot [Options] VM_NAME [SNAPSHOT_NAME]"
  echo
  echo "Options:"
  echo " -h          : This help text"
  echo " -f          : Force delete with -D"
  echo " -d DESCR    : Snapshot description (default: none)"
  echo " -l          : List snapshots for VM_NAME"
  echo " -t          : List snapshots for VM_NAME (tree)"
  echo " -D          : Delete SNAPSHOT_NAME snapshot for VM_NAME"
  echo " -R          : Revert/restore VM_NAME to SNAPSHOT_NAME"
  exit "${1:-0}"
}

snapshot() {
  local mode=create vm="" snapshot="snapshot1" description="" force=false REPLY=""
  local desc=() disks=() disk_opt=() disk="" mem_opt=()
  local OPTIND=1 OPTARG="" opt=""
  while getopts ":hfd:ltDR" opt; do
    case $opt in
      d) description=$OPTARG ;;
      f) force=true ;;
      l) mode=list ;;
      t) mode=list-tree ;;
      D) mode=delete ;;
      R) mode=revert ;;
      h) snapshot_usage ;;
      :) echo "-$OPTARG requires an argument" ; exit 1 ;;
      \?) echo "Unknown option: -$OPTARG" ; exit 1 ;;
    esac
  done
  shift $(( OPTIND - 1 ))

  (( $# == 0 )) && snapshot_usage 1
  vm=$1
  shift

  if [[ "$mode" == list ]]; then
    virsh snapshot-list "$vm"
    return
  elif [[ "$mode" == list-tree ]]; then
    virsh snapshot-list "$vm" --tree
    return
  fi

  if [[ "$mode" == delete ]]; then
    if [[ -z "$1" ]]; then
      echo "Error: SNAPSHOT_NAME must be provided with -D" >&2
      exit 1
    fi
    if ! "$force"; then
      read -rp "Really delete snapshot '$1' for $vm? [yN] "
      if [[ ! "$REPLY" =~ ^(YES|Yes|yes|Y|y|1)$ ]]; then
        echo "Not deleting '$1' for $vm"
        exit
      fi
      echo
    fi
    virsh snapshot-delete "$vm" "$1"
    return
  fi

  if [[ "$mode" == revert ]]; then
    if [[ -z "$1" ]]; then
      echo "Error: SNAPSHOT_NAME must be provided with -R" >&2
      exit 1
    fi
    if ! "$force"; then
      read -rp "Really revert $vm to snapshot '$1'? [yN] "
      if [[ ! "$REPLY" =~ ^(YES|Yes|yes|Y|y|1)$ ]]; then
        echo "Not reverting $vm to '$1'"
        exit
      fi
      echo
    fi
    virsh snapshot-revert "$vm" "$1"
    return
  fi

  snapshot="$1"

  mapfile -t disks < <(virsh domblklist "$vm" --details | awk '$1=="file" && $2=="disk" {print $3}')

  for disk in "${disks[@]}"; do
    disk_opt+=(--diskspec "$disk,snapshot=external")
  done
  if (( ${#disk_opt[@]} == 0 )); then
    echo "Error: Could not determine disks for $vm" >&2
    exit 1
  fi

  if [[ -n "$description" ]]; then
    desc=(--description "$description")
  fi

  # shellcheck disable=SC2174
  [[ ! -d /var/lib/libvirt/qemu/snapshot/"$vm" ]] &&
    mkdir -m 775 -p /var/lib/libvirt/qemu/snapshot/"$vm"

  if ! grep -q "shut off" < <(virsh domstate "$vm"); then
    mem_opt=(--memspec "/var/lib/libvirt/qemu/snapshot/$vm/$snapshot-memory,snapshot=external")
  fi

  virsh snapshot-create-as "$vm" --name "$snapshot" "${desc[@]}" --atomic "${disk_opt[@]}" "${mem_opt[@]}"
}

start_usage() {
  echo "usage: ${0##*} start [Options] VM_NAME"
  echo
  echo "Options:"
  echo " -h          : This help text"
  echo " -c          : Start and attach to console"
  exit "${1:-0}"
}

start() {
  local opts=()
  local OPTIND=1 OPTARG="" opt=""
  while getopts ":hc" opt; do
    case $opt in
      c) opts+=(--console) ;;
      h) start_usage ;;
      :) echo "-$OPTARG requires an argument" ; exit 1 ;;
      \?) echo "Unknown option: -$OPTARG" ; exit 1 ;;
    esac
  done
  shift $(( OPTIND - 1 ))

  (( $# == 0 )) && start_usage 1

  virsh start "$1" "${opts[@]}"
}

stop_usage() {
  echo "usage: ${0##*} stop [Options] VM_NAME"
  echo
  echo "Options:"
  echo " -h          : This help text"
  echo " -f          : Force shutdown (destroy)"
  exit "${1:-0}"
}

stop() {
  local force=false
  local OPTIND=1 OPTARG="" opt=""
  while getopts ":hf" opt; do
    case $opt in
      f) force=true ;;
      h) stop_usage ;;
      :) echo "-$OPTARG requires an argument" ; exit 1 ;;
      \?) echo "Unknown option: -$OPTARG" ; exit 1 ;;
    esac
  done
  shift $(( OPTIND - 1 ))

  (( $# == 0 )) && stop_usage 1

  if $force; then
    virsh destroy "$1"
  else
    virsh shutdown "$1"
  fi
}

get_os_variant() {
  command -v virt-install &>/dev/null || { echo "Error: virt-install is required for this program" >&2 ; exit 1 ; }

  (( $# < 1 )) && { echo "usage: get_os_variant SEARCHSTRING" ; return 1 ; }
  virt-install --osinfo list | \
    awk -F, -v os="$1" '$0 ~ "^" os "([[:digit:]]|$)" { print $1 }' | \
    sort -V | \
    tail -n1
}

get_iso() {
  (( $# < 1 )) && { echo "usage: get_iso ISOSEARCH [VM_ISO]" ; return 1 ; }
  local iso_search=$1 vm_iso=$2 ng=false
  if [[ -z "$vm_iso" ]]; then
    shopt -q ng && ng=true ; shopt -u nullglob
    for iso in "$iso_path"/$iso_search; do
      vm_iso=$(printf "%s\n%s\n" "$vm_iso" "$iso" | grep . | sort -V | tail -n1)
    done
    $ng && shopt -s nullglob ; ng=false
  fi
  [[ -z "$vm_iso"   ]] && { echo "Error: ISO not defined" ; exit 1 ; }
  [[ ! -r "$vm_iso" ]] && { echo "Error: ISO not found"   ; exit 1 ; }
  echo "$vm_iso"
}

main_usage() {
  echo "usage: ${0##*} MODE"
  echo
  echo "MODE can be:"
  echo "  clone    : Create clone of VM"
  echo "  create   : Create a new VM"
  echo "  delete   : Delete/Destroy VM"
  echo "  list     : List VMs"
  echo "  reboot   : Reboot guest"
  echo "  reset    : Forceably reset VM"
  echo "  snapshot : Manage VM snapshots"
  echo "  start    : Start VM"
  echo "  stop     : Stop VM"
  echo "  help     : This help"
  exit "${1:-0}"
}

main() {

  command -v virsh &>/dev/null || { echo "Error: virsh is required for this program" >&2 ; exit 1 ; }

  case "$1" in
    clone|copy|duplicate|dupe) shift ; clone "$@" ;;
    create|new) shift ; create "$@" ;;
    delete|del|remove|rm) shift ; delete "$@" ;;
    list|ls) shift ; list "$@" ;;
    reboot) shift ; reboot "$@" ;;
    reset) shift ; reset "$@" ;;
    snapshot|snap) shift ; snapshot "$@" ;;
    start) shift ; start "$@" ;;
    stop|shutdown|destroy) shift ; stop "$@" ;;
    ''|help|--help|-h)
      shift
      case "$1" in
        clone|copy|duplicate|dupe) clone -h ;;
        create|new) create -h ;;
        delete|del|remove|rm) delete -h ;;
        list|ls) list -h ;;
        reboot) reboot -h ;;
        reset) reset -h ;;
        snapshot|snap) snapshot -h ;;
        start) start -h ;;
        stop|shutdown|destroy) stop -h ;;
        *) main_usage ;;
      esac
      ;;
    -*) create "$@" ;;
    *) echo "Error: Invalid command" >&2 ; main_usage 1
  esac
}

main "$@"

