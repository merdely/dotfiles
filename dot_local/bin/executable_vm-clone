#!/usr/bin/env bash

usage() {
  echo "usage: ${0##*} [Options] SRC_VM DEST_VM"
  echo "Options:"
  echo " -h     : This help text"
  echo " -u     : Connect to hypervisor with libvirt user/session URI (default: system URI)"
  echo " -c URI : Connect to hypervisor with libvirt URI (e.g.: -c qemu:///otherhost.example.com)"
  echo " -l     : List VMs"
  echo
  echo "To use -c with -l, specify -c/-u first"
  exit "${1:-0}"
}

connect=(--connect qemu:///system)
while getopts ":hluc:" opt; do
  case $opt in
    l) virsh "${connect[@]}" list --all ; exit ;;
    u) connect=(--connect qemu:///session) ;;
    c) connect=(--connect "$OPTARG") ;;
    h) usage ;;
    :) echo "-$OPTARG requires an argument" ; exit 1 ;;
    \?) echo "Unknown option: -$OPTARG" ; exit 1 ;;
  esac
done
shift $(( OPTIND - 1 ))

virt-clone "${connect[@]}" --auto-clone --original "$1" --name "$2"

