#!/usr/bin/env bash

progname=${0##*/}
progname=${progname%.sh}

rcfile=${rcfile:-$HOME/.config/firefoxcookiemgrrc}
adguard_list=${adguard_list:-false}
opnsense_dnsmasq=${opnsense_dnsmasq:-false}
opnsenserc=${opnsenserc:-$HOME/.config/opnsenserc}
debug=${debug:-false}
debug_exit=${debug_exit:-false}
usage() {
  echo "usage: $progname [Options]"
  echo "Options:"
  echo "  -h          : show this help text"
  echo "  -c RCFILE   : use FILE for $progname settings instead of $rcfile"
  echo "  -a          : use AdGuard Blocklist from Git to download a list of hostnames"
  echo "  -o          : use OpnSense to download a list of hostnames from dnsmasq"
  echo "  -i SITEFILE : import file saved previously to permissions file specified with -p"
  echo "  -p PERMFILE : permissions database file (e.g. ~/.mozilla/firefox/*.default-default/permissions.sqlite)"
  echo
  echo "For exporting, '-p PERMFILE' or '-a' or '-o' must be given. Output is printed to screen."
  echo "For importing, '-p PERMFILE' and '-i SITEFILE' must be given."
  echo
  echo "  Examples:"
  echo "    Export cookie exception site list:"
  echo "      $progname -p ~/.mozilla/firefox/*.NewProfile/permissions.sqlite > out.txt"
  echo
  echo "    Import cookie exception site list from previous export:"
  echo "      $progname -i out.txt -p ~/.mozilla/firefox/*.NewProfile/permissions.sqlite"
  echo "      NOTE: Firefox must not be running for an import"
  exit "${1:-0}"
}
adguard_list_set=false
opnsense_dnsmasq_set=false
while getopts ":hdDc:aoi:p:" opt; do
  case "$opt" in
    d) debug=true ;;
    D) debug=true ; debug_exit=true ;;
    c) rcfile=$OPTARG ;;
    a) adguard_list=true ; adguard_list_set=true ;;
    o) opnsense_dnsmasq=true ; opnsense_dnsmasq_set=true ;;
    i) import_file=$OPTARG ;;
    p) permissions_file=$OPTARG ;;
    *) usage ;;
  esac
done
shift $(( OPTIND - 1 ))

if [ -r "$rcfile" ]; then
  mapfile -t adguard_list < <(awk -vs="main" -vk="adguard_list" 'BEGIN{p=0}$0~/^\\s*\[/{p=0}$0~"^\\s*\\["s"\\]"{p=1}p==1&&$0~"^\\s*"k"\\s*[:=]"{sub(/^[^:=]+[:=]/,"");if(L=="")sub(/^\s+/,"");if(T=="")sub(/\s+$/,"");if(Q==""){gsub(/^"/,"");gsub(/"$/,"")};print}' "$rcfile")
  mapfile -t opnsense_dnsmasq < <(awk -vs="main" -vk="opnsense_dnsmasq" 'BEGIN{p=0}$0~/^\\s*\[/{p=0}$0~"^\\s*\\["s"\\]"{p=1}p==1&&$0~"^\\s*"k"\\s*[:=]"{sub(/^[^:=]+[:=]/,"");if(L=="")sub(/^\s+/,"");if(T=="")sub(/\s+$/,"");if(Q==""){gsub(/^"/,"");gsub(/"$/,"")};print}' "$rcfile")

  if [[ "${adguard_list[0]}" =~ ^(TRUE|True|true|T|t|YES|Yes|yes|Y|y|ON|On|on|1)$ &&
        "${opnsense_dnsmasq[0]}" =~ ^(TRUE|True|true|T|t|YES|Yes|yes|Y|y|ON|On|on|1)$ ]]; then
    echo "Error: Only one of Adguard List (-a) and OpnSense dnsmasq (-o) can be set" >&2
    exit 1
  fi

  if ! "$adguard_list_set" && [[ "${adguard_list[0]}" =~ ^(TRUE|True|true|T|t|YES|Yes|yes|Y|y|ON|On|on|1)$ ]]; then
    mapfile -t adguard_bw_entry < <(awk -vs="adguard" -vk="bw_entry" 'BEGIN{p=0}$0~/^\\s*\[/{p=0}$0~"^\\s*\\["s"\\]"{p=1}p==1&&$0~"^\\s*"k"\\s*[:=]"{sub(/^[^:=]+[:=]/,"");if(L=="")sub(/^\s+/,"");if(T=="")sub(/\s+$/,"");if(Q==""){gsub(/^"/,"");gsub(/"$/,"")};print}' "$rcfile")
    mapfile -t adguard_bw_uri < <(awk -vs="adguard" -vk="bw_uri" 'BEGIN{p=0}$0~/^\\s*\[/{p=0}$0~"^\\s*\\["s"\\]"{p=1}p==1&&$0~"^\\s*"k"\\s*[:=]"{sub(/^[^:=]+[:=]/,"");if(L=="")sub(/^\s+/,"");if(T=="")sub(/\s+$/,"");if(Q==""){gsub(/^"/,"");gsub(/"$/,"")};print}' "$rcfile")
    adguard_list_url=$(rbw get -f "${adguard_bw_uri[0]}" "${adguard_bw_entry[0]}" 2> /dev/null)
    if [[ -z "$adguard_list_url" ]]; then
      echo "Error: Could not read adguard settings ([adguard] bw_entry or bw_uri) from $rcfile" | fold -s >&2
      exit 1
    fi
  fi

  if ! "$opnsense_dnsmasq_set" && [[ "${opnsense_dnsmasq[0]}" =~ ^(TRUE|True|true|T|t|YES|Yes|yes|Y|y|ON|On|on|1)$ ]]; then
    mapfile -t opnsense_bw_entry < <(awk -vs="opnsense" -vk="bw_entry" 'BEGIN{p=0}$0~/^\\s*\[/{p=0}$0~"^\\s*\\["s"\\]"{p=1}p==1&&$0~"^\\s*"k"\\s*[:=]"{sub(/^[^:=]+[:=]/,"");if(L=="")sub(/^\s+/,"");if(T=="")sub(/\s+$/,"");if(Q==""){gsub(/^"/,"");gsub(/"$/,"")};print}' "$rcfile")
    mapfile -t opnsense_bw_api_key < <(awk -vs="opnsense" -vk="bw_api_key" 'BEGIN{p=0}$0~/^\\s*\[/{p=0}$0~"^\\s*\\["s"\\]"{p=1}p==1&&$0~"^\\s*"k"\\s*[:=]"{sub(/^[^:=]+[:=]/,"");if(L=="")sub(/^\s+/,"");if(T=="")sub(/\s+$/,"");if(Q==""){gsub(/^"/,"");gsub(/"$/,"")};print}' "$rcfile")
    mapfile -t opnsense_bw_api_secret < <(awk -vs="opnsense" -vk="bw_api_secret" 'BEGIN{p=0}$0~/^\\s*\[/{p=0}$0~"^\\s*\\["s"\\]"{p=1}p==1&&$0~"^\\s*"k"\\s*[:=]"{sub(/^[^:=]+[:=]/,"");if(L=="")sub(/^\s+/,"");if(T=="")sub(/\s+$/,"");if(Q==""){gsub(/^"/,"");gsub(/"$/,"")};print}' "$rcfile")
    mapfile -t opnsense_bw_uri < <(awk -vs="opnsense" -vk="bw_uri" 'BEGIN{p=0}$0~/^\\s*\[/{p=0}$0~"^\\s*\\["s"\\]"{p=1}p==1&&$0~"^\\s*"k"\\s*[:=]"{sub(/^[^:=]+[:=]/,"");if(L=="")sub(/^\s+/,"");if(T=="")sub(/\s+$/,"");if(Q==""){gsub(/^"/,"");gsub(/"$/,"")};print}' "$rcfile")
    opnsense_server=$(rbw get -f "${opnsense_bw_uri[0]}" "${opnsense_bw_entry[0]}" 2> /dev/null)
    opnsense_key=$(rbw get -f "${opnsense_bw_api_key[0]}" "${opnsense_bw_entry[0]}" 2> /dev/null)
    opnsense_secret=$(rbw get -f "${opnsense_bw_api_secret[0]}" "${opnsense_bw_entry[0]}" 2> /dev/null)
    if [[ -z "$opnsense_server" || -z "$opnsense_key" || -z "$opnsense_secret" ]]; then
      echo "Error: Could not read opnsense settings ([opnsense] bw_entry, bw_api_key, bw_secret, or bw_uri) from $rcfile" | fold -s >&2
      exit 1
    fi
  fi
else
  echo "Error: Cannot read $rcfile" >&2
  exit 1
fi

if $debug; then
  echo "adguard_list=${adguard_list[0]}"
  echo "opnsense_dnsmasq=${opnsense_dnsmasq[0]}"
  echo "import_file=$import_file"
  echo "permissions_file=$permissions_file"
  [ -n "$opnsense_server" ] && echo "opnsense_server=$opnsense_server"
  [ -n "$opnsense_key" ] && echo "opnsense_key=$opnsense_key"
  [ -n "$opnsense_secret" ] && echo "opnsense_secret=$opnsense_secret"
  [ -n "$adguard_list_url" ] && echo "adguard_list_url=$adguard_list_url"
  echo "debug_exit=$debug_exit"
  $debug_exit && exit
fi

if [[ -n "$import_file" && -z "$permissions_file" ]]; then
  echo "Error: '-i SITEFILE' and '-p FILE' are required for importing sites." >&2
  exit 1
elif [[ -n "$import_file" && -n "$permissions_file" ]]; then
  [[ ! -r "$import_file" ]] && echo "Error: Cannot read file for -i ($import_file)" && exit 1
  [[ ! -r "$permissions_file" ]] && echo "Error: Cannot read file for -i ($permissions_file)" && exit 1
  if ! sqlite3 -readonly "$permissions_file" ".tables" | grep -q moz_perms > /dev/null 2>&1; then
    echo "Error: Either $permissions_file is correct, not a Sqlite file, or is locked"
    exit 1
  fi
  goodcount=$(grep -Ec "^(https?://|about:)" "$import_file")
  badcount=$(grep -Evc "^(https?://|about:)" "$import_file")
  [[ "$badcount" != 0 ]] && echo "Error: $import_file has non-websites in it" && exit 1
  [[ "$goodcount" = 0 ]] && echo "Error: $import_file has no websites in it" && exit 1

  last=$(sqlite3 -readonly "$permissions_file" "select id from moz_perms order by id" | tail -n1)
  [[ ! $last =~ ^[0-9]+$ ]] && last=0
  next=$((last+1))
  add=0
  notadd=0
  line=""
  while IFS=$'\n' line; do
    out=$(sqlite3 -readonly "$permissions_file" \
      "select id from moz_perms where type='cookie' and origin='$line'")
    [[ -n "$out" ]] && notadd=$((notadd+1))
    if [[ -z "$out" ]]; then
      time=$(date +%s%N)
      sqlite3 "$permissions_file" "INSERT INTO moz_perms(id,origin,type,permission,expireType,expireTime,modificationTime) VALUES($next,'$line','cookie',1,0,0,${time:0:-6});"
      add=$((add+1))
      next=$((next+1))
    fi
  done <<< "$import_file"
  echo Added $add sites
  echo Did not need to add $notadd sites
else
  unsort=$(mktemp)
  sorted=$(mktemp)

  # If using an OpnSense dnsmasq list, extract hostnames
  if ${opnsense_dnsmasq[0]}; then
    curl -sL -X GET -u "$opnsense_key:$opnsense_secret" "$opnsense_server"/api/dnsmasq/settings/download_hosts | python3 -c "
      import csv
      import sys
      reader = csv.reader(sys.stdin)
      next(reader, None)
      for row in reader:
          #parts = []
          if row[0] and row[1]:
              # parts.append(f'{row[0]}.{row[1]}')
              print(f'https://{row[0]}.{row[1]}')
          if len(row) >= 12 and row[11]:
              #parts.append(row[11])
              print(f\"https://{row[11].replace(',','\nhttps://')}\")
      " >> "$unsort"
  fi # if $opnsense

  # If using an AdGuard list, extract hostnames
  if ${adguard_list[0]}; then
    curl -s "$adguard_list_url" | awk -F '[|^;]' '/;(A|CNAME);/{sub(/^https?:\/\//,"");print "https://" $2}' | grep -Ev "(adguard\.adguard)$" >> "$unsort"
  fi

  db=$(mktemp)

  [[ ! -r "$permissions_file" ]] && { echo "Error: Could not find permissions file ($permissions_file)" >&2 ; exit 1 ; }

  cp "$permissions_file" "$db"

  sqlite3 -readonly "$db" "select origin from moz_perms where type='cookie'" | grep -vE "(erdely\.co|erdely\.in|erde\.ly|erdelynet\.com)$" >> "$unsort"

  sort -u "$unsort" > "$sorted"
  cat "$sorted"
  rm -f "$unsort" "$sorted" "$db"
fi

