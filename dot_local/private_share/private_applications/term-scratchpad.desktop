# vim: set filetype=desktop :
# NOTE: Do not edit this file directly
# Use: chezmoi edit ~/.local/share/applications/term-scratchpad.desktop

[Desktop Entry]
Exec=/home/mike/.local/bin/x-terminal-emulator -e --class term-scratchpad --title "Terminal Scratchpad"
Name=Terminal Scratchpad
Icon=utilities-terminal
StartupNotify=false
Type=Application
X-KDE-GlobalAccel-CommandShortcut=true
