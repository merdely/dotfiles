# vim: set filetype=desktop :
# NOTE: Do not edit this file directly
# Use: chezmoi edit ~/.local/share/applications/termfm.desktop

[Desktop Entry]
Exec=bash -c "$HOME/.local/bin/x-terminal-emulator --title Yazi -e --class termfm yazi"
Name=Terminal File Manager
Icon=utilities-terminal
StartupNotify=false
Type=Application
X-KDE-GlobalAccel-CommandShortcut=true
