# vim: set filetype=desktop :
# NOTE: Do not edit this file directly
# Use: chezmoi edit ~/.local/share/applications/udiskie-applet.desktop

[Desktop Entry]
Name=Udiskie Applet
Comment=Automounter for Removable Media
Icon=drive-removable-media-usb
Exec=udiskie --no-menu-update-workaround --menu flat --no-file-manager --no-terminal --tray
Terminal=false
Type=Application
StartupNotify=true
Categories=GTK;GNOME;Settings;HardwareSettings;
