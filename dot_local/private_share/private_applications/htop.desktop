# Use: chezmoi edit ~/.local/share/applications/htop.desktop

[Desktop Entry]
Exec=/home/mike/.local/bin/x-terminal-emulator -e --class htop htop
Name=Htop
Icon=htop
StartupNotify=false
Type=Application
X-KDE-GlobalAccel-CommandShortcut=true
