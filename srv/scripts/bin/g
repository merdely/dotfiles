#!/bin/sh

progname=${0##*/}
progname=${progname%.sh}

case $progname in
  ga)
    action=add
    ;;
  gp)
    action=push
    ;;
  gd)
    action=diff
    ;;
  *)
    action=commit
    ;;
esac

usage() {
  if [ $action = add ]; then
    echo "usage: $progname [-h] [-C dir] file1 [.. fileN]"
  elif [ $action = push ] || [ $action = diff ]; then
    echo "usage: $progname [-h] [-C dir] [..]"
  else
    echo "usage: $progname [-h] [-C dir] [-S|--skip-ci] [--allow-empty] --allow-empty-message|COMMIT MESSAGE"
    echo "For 'COMMIT MESSAGE' to contain new lines, use '\n'"
    echo "If passing 'COMMIT MESSAGE without quotes, use '\\\n'"
  fi
  exit
}

shopt -s extglob

unset dir allow_empty
test_mode=false
allow_empty_message=false
skip_ci=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    -t|--test) test_mode=true ; shift ;;
    -C) [[ -z "$2" || $2 =~ ^- ]] && shift && echo "Error: Missing argument" && usage 1; dir=$2 ; shift 2 ;;
    -S|--skip-ci) skip_ci=true ; shift ;;
    --allow-empty) allow_empty="--allow-empty" ; shift ;;
    --allow-empty-message) allow_empty_message=true ; shift ;;
    -h|--help) usage ;;
    *) break ;;
  esac
done

[ -z "$1" ] && ! $allow_empty_message && [ $action != push ] && [ $action != diff ] && usage

commitmsg=$(echo "$@")
$skip_ci && commitmsg="$commitmsg [skip ci]"

if $test_mode; then
  [ -z "$dir" ] && dir=.
  if [ $action = add ]; then
    echo "Running 'git add'"
    for f in "${args[@]:1}"; do
      echo " - $f"
    done
  elif [ $action = push ]; then
    echo "Running 'git push'"
    echo "Additional args: '$@'"
  elif [ $action = diff ]; then
    echo "Running 'git diff'"
    echo "Additional args: '$@'"
  else
    echo "Running 'git commit -a' and 'git push'"
    [ -n "$allow_empty" ] && echo "Empty commits allowed"
    $allow_empty_message && echo "Empty commit messages allowed"
    echo "commit message = '$commitmsg'"
  fi
  echo "Using dir $dir"
  exit
fi

if [ $action = add ]; then
  git ${dir:+-C $dir }add "$@"
elif [ $action = push ]; then
  git ${dir:+-C $dir }push "$@"
elif [ $action = diff ]; then
  git ${dir:+-C $dir }diff "$@"
else
  if $allow_empty_message && [ -z "$commitmsg" ]; then
    git ${dir:+-C $dir }commit -a --allow-empty-message
  else
    git ${dir:+-C $dir }commit -a -m "$(printf "$commitmsg")"
  fi
  git ${dir:+-C $dir }push
fi
