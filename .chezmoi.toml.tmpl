# vim: set filetype=toml :
progress = true

[data]
    trusted_hosts = ["earth", "carme", "mercury", "neptune", "uranus"]

[edit]
    apply = true

[git]
    autoCommit = true
    autoPush = true

{{- if and (eq .chezmoi.hostname "mercury") (eq .chezmoi.username "mike") }}

[hooks.apply.pre]
command = "chezmoi"
args = ["re-add", "~/.cache/rofi-rbw.runcache"]

[hooks.update.pre]
command = "chezmoi"
args = ["re-add", "~/.cache/rofi-rbw.runcache"]
{{- end }}

[hooks.read-source-state.pre]
command = ".local/share/chezmoi/.prep-chezmoi.sh"
