# Remove a directory from PATH
path_prune() {
  [[ -z "$1" ]] && return 1
  local left_side right_side="$PATH:"

  # Loop through the PATH variable, moving elements from the right to the left,
  # skipping the prune-part
  while [[ -n "$right_side" ]]; do
    [[ "$1" != "${right_side%%:*}" ]] && left_side="${left_side}:${right_side%%:*}"
    right_side=${right_side#*:}
  done
  export PATH=${left_side#:}
}

# Intelligently add a directory to PATH
path_add() {
  local before=false
  [[ "$1" == "-b" ]] && before=true && shift
  [[ -z "$1" ]] && return 1
  path_prune "$1"
  if "$before"; then
    export PATH="$1":"$PATH"
  else
    export PATH="$PATH":"$1"
  fi
}

# For use in PS1, better PROMPT_DIRTRIM/\w
__prompt_trim_pwd() {
    local default=${1:-\\w}
    [[ -z "$BASH_VERSION" ]] && { echo "$default" ; return 0 ; }
    local ellipsis="…" pwd=${PWD/#$HOME/\~} parts trimmed
    [[ -z "$PROMPT_DIRTRIM" || "$PROMPT_DIRTRIM" -lt 1 ]] && { echo "$default" ; return 1 ; }
    eval 'IFS=/ read -ra parts <<< "$pwd"'
    if (( ${#parts[@]} == 0 )); then
      echo "$default" ; return 1
    elif [[ "${parts[0]}" == "~" && "${#parts[@]}" -gt $(( PROMPT_DIRTRIM + 2 )) ]]; then
        trimmed=${parts[*]: -$PROMPT_DIRTRIM}
        echo "~/${ellipsis}/${trimmed// //}"
    elif [[ "${parts[0]}" != "~" && "${#parts[@]}" -gt $(( PROMPT_DIRTRIM + 1 )) ]]; then
        trimmed=${parts[*]: -$PROMPT_DIRTRIM}
        echo "${ellipsis}/${trimmed// //}"
    else
        echo "$pwd"
    fi
}

