# Get file age
fileage() {
  mode=seconds
  verbose=false
  local opt OPTIND=1 str filename
  local usage="usage: fileage [-v] [-s|-m|-h|-d|-y] FILE\n         -v         : print label\n         -s|m|h|d|y : seconds|minutes|days|years (default: seconds)\n"
  while getopts ":hsmhdyv" opt; do
    case $opt in
      s) mode=seconds ; mult=1 ;;
      m) mode=minutes ; mult=60 ;;
      h) [[ -z "$2" || ${2:0:1} == - ]] && { printf "%b" "$usage" >&2 ; return 1 ; }
         mode=hours   ; mult=$((60 * 60)) ;;
      d) mode=days    ; mult=$((60 * 60 * 24)) ;;
      y) mode=years    ; mult=$((60 * 60 * 24 * 365)) ;;
      v) verbose=true ;;
      *) printf "%b" "$usage" && return 1 ;;
    esac
  done
  shift $((OPTIND -1))
  $verbose && str=" $mode"
  filename=$(realpath "$1")
  [[ ! -r "$filename" ]] && { echo "Error: Cannot find $filename" >&2 ; return 1 ; }
  echo $(( ($(date +%s) - $(stat -c %Y "$filename")) / $((${mult:-1})) ))"$str"
}

command -v firejail > /dev/null 2>&1 && \
fj() {
  [[ -z "$1" ]] && { echo "usage: fj FIREJAILED_APP" >&2 ; return 1 ; }
  [[ "$1" == -l ]] && { firejail --list | awk -F: '! /(\/usr\/bin\/)?firejail --join/{sub(/^(\/usr\/bin\/)?firejail /,"",$NF);print $NF}' ; return ; }
  echo "$1" | grep -q firejail && { echo "Error: 'firejail' cannot be used in app string" >&2 ; return 1 ; }
  app_pid=$(firejail --list | awk -F: "/$1/ { print \$1 }")
  count=$(echo "$app_pid" | wc -w)
  if (( count == 0 )); then
    echo "Error: No matches found for '$1'" >&2
    return 1
  elif (( count > 1 )); then
    echo "Error: More than one match found for '$1'" >&2
    return 1
  fi
  echo "$app_pid"|grep -Eq "^[0-9]+$" || { echo "Error: Invalid FIREJAILED_APP (pid: $app_pid)" >&2 ;return 1; }
  firejail --join="$app_pid" bash
}

# OS Specific Commands
case "$ID" in
  arch|archarm)
    alias ls_orphans='pacman -Qdtq'
    alias rm_orphans='o=$(pacman -Qdtq); [[ -n "$o" ]] && echo Removing "$o" && sudo pacman -Rcns "$o"; unset o'
    alias updates='echo Using pacman; sudo pacman -S --needed archlinux-keyring ; sudo pacman -Syu --noconfirm'
    ;;
  debian|ubuntu)
    alias updates='echo Using apt dist-upgrade; sudo apt update && sudo apt dist-upgrade -y'
    ;;
  OpenBSD)
    # Print status of command without interrupting it (e.g. ping)
    stty status '^T'
    export LESS=FRSXc
    alias updates="echo running syspatch; doas syspatch; echo running pkg_add -u; doas pkg_add -ui"

    # Allow ps on OpenBSD to accept -ef
    ps() {
      local W
      if [[ $(echo "$1" | cut -b 1-3) == "-ef" ]]; then
        [[ "$*" == *w* ]] && W=-w
        [[ "$*" == *ww ]] && W=-ww
        /bin/ps -A -o user,pid,ppid,pcpu,start,tty,time,args "$W"
      else
        /bin/ps "$@"
      fi
    }

    # Shortcuts for using halt and reboot with shutdown group membership
    if groups | grep -qw _shutdown; then
      halt_func() { shutdown -h "$@" now; } ; alias halt=halt_func
      reboot_func() { shutdown -r "$@" now; } ; alias reboot=reboot_func
    fi
    ;;
esac

