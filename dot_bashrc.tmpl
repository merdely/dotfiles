# Set up a basic prompt
unset __subshell
[[ "$CHEZMOI_SUBSHELL" == 1 ]] && __subshell=" {C}"
[[ "$TERM" == vt220 ]] && { unset __gitglyph ; }
PS1="[\u@\h \$(__prompt_trim_pwd '\W')]\${__subshell}\$(__git_ps1 ' (${__gitglyph}%s)' 2>/dev/null) \\$ "

# Set the prompt for bash
if [[ -n "$BASH_VERSION" ]]; then
  # \1 & \2 are good for the vi-ins-mode-string but \[ and \] are good for PS1
  # Colors: black:30, red:31, green:32, yellow:33, blue:34, magenta:35, cyan:36, white:37
  # foreground:38, background:48, reset_foreground:39, reset_background:49
  # bright_foreground:+60, bright_background:+70
  # bold:1, unbold:22, underline:4, un-underline:24, reverse:7, unreverse:27
  # orange:38;2;255;165;0 (a little darker: 38;5;208

  # Set up a good looking orange
  __orange='0;33'
  [[ "$TERM" != linux && "$TERM" != vt220 ]] && __orange='38;5;208'

  PROMPT_DIRTRIM=2
  shopt -s autocd cdspell extglob histappend

  # Show the mode in the prompt
  bind 'set show-mode-in-prompt on'

  # Lower the timeout for pressing escape
  bind 'set keyseq-timeout 100'

  # Set emacs-mode and vi-ins-mode to reset codes
  bind "set emacs-mode-string \"\1\e[1m\2\""
  bind "set vi-ins-mode-string \"\1\e[1m\2\""

  # Set vi-cmd-mode string to reverse mode
  bind "set vi-cmd-mode-string \"\1\e[0m\2\""

  # Rebuild prompt command with exit status and history commands
  eval 'IFS=";" read -ra parts <<< "$PROMPT_COMMAND"'
  PROMPT_COMMAND=""
  for part in "${parts[@]}"; do
    [[ -z "$part" || "$part" == "history "* || "$part" == "__prompt_exit="* || "$part" == ":" ]] && continue
    PROMPT_COMMAND="$PROMPT_COMMAND;$part"
  done
  PROMPT_COMMAND="__prompt_exit=\$?$PROMPT_COMMAND;history -a;history -c;history -r"
  unset parts part

  # Set prompt color based on exit status of last command
  __prompt_dollar() { ((__prompt_exit != 0)) && printf '\e[91m' || printf '\e[92m'; }

  # Set the prompt
  [[ "$CHEZMOI_SUBSHELL" == 1 ]] && __subshell=$' \1\e[1;95m\2{C}\1\e[22;39m\2'
  PS1="[\[\e[96m\]\u\[\e[39m\]@\[\e[92m\]\h\[\e[39m\] \[\e[94m\]\$(__prompt_trim_pwd "\W")\[\e[39m\]]\[\e[22;24;27;49m\]\${__subshell}\$(__git_ps1 ' (\[\e[1;${__orange}m\]${__gitglyph}\[\e[1;39m\]%s\[\e[22m\])' 2>/dev/null) \[\$(__prompt_dollar)\]\\$\[\e[39m\] \[\e[0m\]"
  unset __gitglyph

  # Set readline options
  bind 'set completion-ignore-case on'     # ignore case
  bind 'set completion-map-case on'        # treat hyphens and underscores the same
  #bind 'set show-all-if-ambiguous on'      # show all completions on first tab
  bind 'set show-all-if-unmodified on'     # show all completions on first tab with no partial match
  bind 'set colored-stats on'              # types in ls-style colors
  bind 'set colored-completion-prefix on'  # display common prefix in ls-style colors
  bind 'set mark-symlinked-directories on' # show directory symlinks with trailing slash
  bind 'set visible-stats on'              # append character indicating type
fi

# Load fzf for command history for bash and zsh
if cmdcheck fzf; then
  if [[ -n "$BASH_VERSION" ]]; then
    type __fzf_history__ > /dev/null 2>&1 || eval "$(fzf --bash)"
  elif [[ -n "$ZSH_VERSION" ]]; then
    type fzf-history-widget > /dev/null 2>&1 || eval 'source <(fzf --zsh)'
  fi
fi

# Use vi-mode
set -o vi

if cmdcheck docker; then
  dr() {
    (( $# < 1 )) && return 1
    local name_base=dr_"${1%%:*}" name=dr_"${1%%:*}" ok=false existing tag
    while ! $ok; do
      ok=true
      for existing in $(docker ps -a --format '{{ "{{" }}.Names}}'); do
        if [[ "$name" == "$existing" ]]; then
          ok=false
          [[ -z "$tag" ]] && tag=0 || tag=$(( tag + 1 ))
          name=$name_base.$tag
        fi
      done
    done
    docker run --rm -it --name "$name" "$1" sh -c "command -v bash>/dev/null && exec bash || exec ash"
  }
fi

# Create SSH ctl directory
[[ ! -d "$XDG_RUNTIME_DIR"/ssh-ctl ]] && mkdir -pm 700 "$XDG_RUNTIME_DIR"/ssh-ctl
[[ ! -L "$HOME"/.ssh/ctl ]] && ln -s "$XDG_RUNTIME_DIR"/ssh-ctl "$HOME"/.ssh/ctl

# SSH key stuff
[[ ! -e "$XDG_RUNTIME_DIR"/ssh-auth-sock && -n "$SSH_AUTH_SOCK" ]] && \
  ln -sf "$SSH_AUTH_SOCK" "$XDG_RUNTIME_DIR"/ssh-auth-sock
if [[ -n "$SSH_CONNECTION" && ! -S "$XDG_RUNTIME_DIR"/ssh-auth-sock && -S "$SSH_AUTH_SOCK" ]]; then
  ln -sf "$SSH_AUTH_SOCK" "$XDG_RUNTIME_DIR"/ssh-auth-sock
fi

# Random password generator
if ! cmdcheck passgen; then
  passgen() {
    LENGTH=$1
    tr -cd '[:alnum:]' < /dev/urandom | fold -w "${LENGTH:-64}" | head -n 1 | tr -d '\n' ; echo
  }
fi
! cmdcheck genpass && alias genpass=passgen

# Get file age
fileage() {
  mode=seconds
  verbose=false
  local opt OPTIND=1 str filename
  local usage="usage: fileage [-v] [-s|-m|-h|-d|-y] FILE\n         -v         : print label\n         -s|m|h|d|y : seconds|minutes|days|years (default: seconds)\n"
  while getopts ":hsmhdyv" opt; do
    case $opt in
      s) mode=seconds ; mult=1 ;;
      m) mode=minutes ; mult=60 ;;
      h) [[ -z "$2" || ${2:0:1} == - ]] && { printf "%b" "$usage" >&2 ; return 1 ; }
         mode=hours   ; mult=$((60 * 60)) ;;
      d) mode=days    ; mult=$((60 * 60 * 24)) ;;
      y) mode=years    ; mult=$((60 * 60 * 24 * 365)) ;;
      v) verbose=true ;;
      *) printf "%b" "$usage" && return 1 ;;
    esac
  done
  shift $(( OPTIND - 1 ))
  $verbose && str=" $mode"
  filename=$(realpath "$1")
  [[ ! -r "$filename" ]] && { echo "Error: Cannot find $filename" >&2 ; return 1 ; }
  echo $(( ($(date +%s) - $(stat -c %Y "$filename")) / $((${mult:-1})) ))"$str"
}

cmdcheck firejail && \
fj() {
  [[ -z "$1" ]] && { echo "usage: fj FIREJAILED_APP" >&2 ; return 1 ; }
  [[ "$1" == -l ]] && { firejail --list | awk -F: '! /(\/usr\/bin\/)?firejail --join/{sub(/^(\/usr\/bin\/)?firejail /,"",$NF);print $NF}' ; return ; }
  echo "$1" | grep -q firejail && { echo "Error: 'firejail' cannot be used in app string" >&2 ; return 1 ; }
  app_pid=$(firejail --list | awk -F: "/$1/ { print \$1 }")
  count=$(echo "$app_pid" | wc -w)
  if (( count == 0 )); then
    echo "Error: No matches found for '$1'" >&2
    return 1
  elif (( count > 1 )); then
    echo "Error: More than one match found for '$1'" >&2
    return 1
  fi
  echo "$app_pid"|grep -Eq "^[0-9]+$" || { echo "Error: Invalid FIREJAILED_APP (pid: $app_pid)" >&2 ;return 1; }
  firejail --join="$app_pid" bash
}

# OS Specific Commands
case "$DISTRO" in
  openbsd)
    # Print status of command without interrupting it (e.g. ping)
    stty status '^T'

    # Allow ps on OpenBSD to accept -ef
    ps() {
      local W
      if [[ $(echo "$1" | cut -b 1-3) == "-ef" ]]; then
        [[ "$*" == *w* ]] && W=-w
        [[ "$*" == *ww ]] && W=-ww
        /bin/ps -A -o user,pid,ppid,pcpu,start,tty,time,args "$W"
      else
        /bin/ps "$@"
      fi
    }

    # Shortcuts for using halt and reboot with shutdown group membership
    if groups | grep -qw _shutdown; then
      halt_func() { shutdown -h "$@" now; } ; alias halt=halt_func
      reboot_func() { shutdown -r "$@" now; } ; alias reboot=reboot_func
    fi
    ;;
esac

# Some host-specific settings
if [[ "$HOSTNAME" == "mercury" ]]; then
  # Arch only settings
  [ ! -d $XDG_RUNTIME_DIR/tmp ] && mkdir -p $XDG_RUNTIME_DIR/tmp

  pushprofile() {
    local f list ros roh out
    cd "$HOME" || return 1
    list="jupiter earth carme metis sinope tarvos neso"
    [[ -n "$1" ]] && list="$*"
    roh=" carme metis sinope tarvos neso "
    for f in $list; do
      echo "$f"
      out=$(rsync -a -4 --info=NAME --relative --recursive \
        .config/shell/merdely.profile "$f": 2>&1 | tee /dev/stderr)
      [[ -n "$out" && $roh == *" $f "* ]] && ros="$ros $f"
    done
    for f in $ros; do
      [[ " $list " == *" $f "* ]] || continue
      echo "$f: sync_home"
      ssh -4 -o ClearAllForwardings=yes root@"$f" /home/mike/.local/bin/sync_home > /dev/null
    done
  }

  pushknownhosts() {
    local f list
    list="mercury jupiter earth carme metis tarvos"
    [[ -n "$1" ]] && list="$*"
    for f in $list; do
      [[ " carme metis tarvos " == *" $f "* ]] && continue
      echo "$f"
      scp "$HOME"/src/ansible/system-setup/roles/sshclient/files/ssh_known_hosts \
        root@"$f":/etc/ssh/ssh_known_hosts
    done
    for f in carme metis tarvos; do
      [[ " $list " == *" $f "* ]] || continue
      echo "$f"
      ssh -o ClearAllForwardings=yes root@"$f" /usr/local/bin/rw
      scp "$HOME"/src/ansible/system-setup/roles/sshclient/files/ssh_known_hosts \
        root@"$f":/etc/ssh/ssh_known_hosts
      ssh -o ClearAllForwardings=yes root@"$f" /usr/local/bin/ro
    done
  }

  pushvimrc() {
    local f list ros roh out
    cd "$HOME" || return 1
    list="jupiter earth carme metis sinope tarvos"
    [[ -n "$1" ]] && list="$*"
    roh=" carme metis sinope tarvos "
    for f in $list; do
      echo "$f"
      out=$(rsync -a --info=NAME --relative --recursive \
        .config/vim/vimrc "$f": 2>&1 | tee /dev/stderr)
      [[ -n "$out" && $roh == *" $f "* ]] && ros="$ros $f"
    done
    for f in $ros; do
      [[ " $list " == *" $f "* ]] || continue
      echo "$f: sync_home"
      ssh -o ClearAllForwardings=yes root@"$f" /home/mike/.local/bin/sync_home > /dev/null
    done
  }
fi

