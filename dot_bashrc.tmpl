# Set umask early
umask 0022 > /dev/null 2>&1

# Load environment variables
[ -r "$HOME"/.config/shell/variables ] && . "$HOME"/.config/shell/variables

# Stop if non-interactive
[[ $- != *i* ]] && return

# Load aliases
[ -r "$HOME"/.config/shell/aliases ] && . "$HOME"/.config/shell/aliases

# For use in PS1, better PROMPT_DIRTRIM/\w
__prompt_trim_pwd() {
    local default=${1:-\\w}
    [[ -z "$BASH_VERSION" ]] && { echo "$default" ; return 0 ; }
    local ellipsis="…" pwd=${PWD/#$HOME/\~} parts trimmed
    [[ -z "$PROMPT_DIRTRIM" || "$PROMPT_DIRTRIM" -lt 1 ]] && { echo "$default" ; return 1 ; }
    eval 'IFS=/ read -ra parts <<< "$pwd"'
    if (( ${#parts[@]} == 0 )); then
      echo "$default" ; return 1
    elif [[ "${parts[0]}" == "~" && "${#parts[@]}" -gt $(( PROMPT_DIRTRIM + 2 )) ]]; then
        trimmed=${parts[*]: -$PROMPT_DIRTRIM}
        echo "~/${ellipsis}/${trimmed// //}"
    elif [[ "${parts[0]}" != "~" && "${#parts[@]}" -gt $(( PROMPT_DIRTRIM + 1 )) ]]; then
        trimmed=${parts[*]: -$PROMPT_DIRTRIM}
        echo "${ellipsis}/${trimmed// //}"
    else
        echo "$pwd"
    fi
}

# Load git prompt
if cmdcheck git; then
  unalias __git_ps1 > /dev/null 2>&1
  for file in "$HOME"/.local/bin/git-prompt.sh /usr/lib/git-core/git-sh-prompt \
              /usr/share/git-core/git-prompt.sh /usr/share/git/completion/git-prompt.sh
  do [[ -e "$file" ]] && . "$file" && break; done
  unset file

  if ! typeset -f __git_ps1 > /dev/null 2>&1; then
    [[ ! -d "$HOME"/.local/bin ]] && mkdir -p "$HOME"/.local/bin
    curl -sLo "$HOME"/.local/bin/git-prompt.sh \
      https://raw.githubusercontent.com/git/git/refs/heads/master/contrib/completion/git-prompt.sh
    [[ -s "$HOME"/.local/bin/git-prompt.sh ]] && . "$HOME"/.local/bin/git-prompt.sh
  fi

  if typeset -f __git_ps1 > /dev/null 2>&1; then
    GIT_PS1_COMPRESSSPARSESTATE=true
    GIT_PS1_SHOWDIRTYSTATE=true
    GIT_PS1_SHOWUNTRACKEDFILES=true
    GIT_PS1_SHOWSTASHSTATE=true
    GIT_PS1_SHOWUPSTREAM="auto"  # auto verbose name legacy git svn
    unset GIT_PS1_SHOWCOLORHINTS
    [[ -z "$KSH_VERSION" ]] && GIT_PS1_SHOWCOLORHINTS=true
    __gitglyph="§ "  # unicode section sign
    [[ "$TERM" != linux ]] && __gitglyph=" "  # git branch symbol from nerd fonts
  fi
  pgrep -x gpg-agent > /dev/null 2>&1 || export GPG_TTY=$(tty)
fi
typeset -f __git_ps1 > /dev/null 2>&1 || alias __git_ps1=true

