# Set Up Prompt
__prompt_trim_pwd() {
  local default=${1:-\\w}
  [[ -z "$PROMPT_DIRTRIM" || "$PROMPT_DIRTRIM" -lt 1 ]] && { echo "$default" ; return 1 ; }
  local pwd=${PWD#"$HOME"} p="" parts="" i=$len limit=$PROMPT_DIRTRIM
  local len=${#parts[@]} out=""
  [ "$pwd" != "$PWD" ] && pwd="~$pwd"
  [ "$pwd" != "/" ] && pwd=${pwd%/}
  IFS=/
  for p in $pwd; do parts[${#parts[@]}]=$p; done
  IFS=$(printf ' \t\n')
  if { [ "${parts[0]}" != "~" ] && [ ${#parts[@]} -lt $(( PROMPT_DIRTRIM + 2 )) ]; } || \
     { [ "${parts[0]}" = "~" ] && [ ${#parts[@]} -lt $(( PROMPT_DIRTRIM + 3 )) ]; }; then
    echo "$pwd"
    exit
  fi
  while [ "$i" -gt 0 ]; do
    i=$(( i - 1 ))
    [ "$limit" -gt 0 ] && limit=$(( limit - 1 )) && continue
    if [ $i -eq 0 ] && [ "${parts[$i]}" = "~" ]; then
      # shellcheck disable=SC2088
      parts[i]="~/$dots"
    elif [ "$i" -eq 0 ]; then
      parts[i]="$dots"
    else
      unset "parts[$i]"
    fi
  done
  # shellcheck disable=SC2048
  for f in ${parts[*]}; do out="$out/$f"; done
  echo "${out#/}"
}

c_red='\e[91m'
c_green='\e[92m'
c_blue='\e[94m'
c_magenta='\e[95m'
c_cyan='\e[96m'
c_orange='\e[38;5;208m'
c_reset='\e[39m'
if [[ "$TERM" == "linux" || "$TERM" == "vt220" ]]; then
  c_red='\e[31m'
  c_green='\e[32m'
  c_blue='\e[34m'
  c_magenta='\e[35m'
  c_cyan='\e[36m'
  c_orange='\e[33m'
fi

PROMPT_DIRTRIM=2
__nl='\n'
[[ "$TERM" != "vt220" && ${COLUMNS:-80} -ge 90 ]] && unset __nl
GIT_PS1_COLOR_PRE='\['
GIT_PS1_COLOR_POST='\]'

# shellcheck disable=SC2016
git_c_on='\[\e[1m${c_orange}\]'
# shellcheck disable=SC2016
git_c_off='\[${c_reset}\]'
[[ "$OSTYPE" != linux* ]] && [[ $(uname -s) = OpenBSD ]] && unset git_c_on git_c_off

# Prompt variable: '[\u@\h \W] \$' with formatting
 PS1="\${PRE_PROMPT}\[\e[1m\][\[${c_cyan}\]\u\[${c_reset}\]@\[${c_green}\]\h\[${c_reset}\] \[${c_blue}\]\$(__prompt_trim_pwd '\W')\[${c_reset}\]]\[\e[22;24;27;49m\]\[\e[1m\]\$(__git_ps1 \" (${git_c_on}${git_s} ${git_c_off}%s)\")\[\e[22m\] \${__nl}\[${c_blue}\]\[\${pchar}\]\[\e[0m\] "

