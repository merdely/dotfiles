# vim: set filetype=toml :

{{- $use_pass := false -}}
{{- $is_desktop := promptBoolOnce . "is_desktop" "Is this system a desktop?" false -}}
{{- if and (lookPath "pass") (lookPath "gpg") (exec "gpg" "--list-secret-keys" "801D19B7706D19AE4663426338D39B589EE2D1DD") -}}
{{-   $use_pass = true -}}
{{- end -}}
{{- "" -}}

progress = true

[data]
    use_pass = {{ $use_pass }}
    is_desktop = {{ $is_desktop }}

[edit]
    apply = true

[git]
    autoCommit = true
    autoPush = true

{{- if and (eq .chezmoi.hostname "mercury") (eq .chezmoi.username "mike") }}

[hooks.apply.pre]
command = "chezmoi"
args = ["re-add", "~/.cache/rofi-rbw.runcache"]

[hooks.update.pre]
command = "chezmoi"
args = ["re-add", "~/.cache/rofi-rbw.runcache"]
{{- end }}

[hooks.read-source-state.pre]
command = ".local/share/chezmoi/home/.prep-chezmoi.sh"
