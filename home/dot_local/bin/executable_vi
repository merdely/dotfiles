#!/usr/bin/env bash

# Delete any tmpfiles on exit
TMPFILES=()
trap 'rm -Rf -- "${TMPFILES[@]}"' EXIT
trap 'exit 1' INT TERM

# Find and set editor
if [[ -n "$EDITOR" ]] && vi_cmd=$(command -v $EDITOR 2> /dev/null); then
  EDITOR=$vi_cmd
elif vi_cmd=$(command -v nvim 2> /dev/null); then
  EDITOR=$vi_cmd
elif vi_cmd=$(command -v vim 2> /dev/null); then
  EDITOR=$vi_cmd
elif vi_cmd=$(command -v vi 2> /dev/null) && [[ "$(realpath "$0")" != "$vi_cmd" ]]; then
  EDITOR=$vi_cmd
else
  echo "Error: Cannot find neovim or vim or other editor" >&2
  exit 1
fi

# Find "tmp" directory that supports running scripts
find_exec_dir() {
  local candidates=("${XDG_RUNTIME_DIR:-}" "${XDG_CACHE_HOME:-$HOME/.cache}" "$HOME/.local/run" /tmp /var/tmp /dev/shm)
  for dir in "${candidates[@]}"; do
    [[ -z "$dir" ]] && continue;mkdir -p "$dir" 2>/dev/null || continue
    local probe;probe=$(mktemp "$dir/probe.XXXXXX") || continue
    printf '#!/bin/sh\n' > "$probe";chmod +x "$probe"
    if "$probe" 2>/dev/null; then rm -f "$probe";printf '%s' "$dir";return 0;fi
    rm -f "$probe"
  done;return 1
}

# Warn if running with sudo -- use sudoedit
if [[ -n "$SUDO_USER" ]] && [[ "$(ps -o comm= -p $PPID)" == "sudo" ]]; then
  echo "Use sudoedit" >&2
  exit 1
else
  flags=()
  editor_files=()
  chezmoi_files=()
  past_flags=false
  if [[ "$(hostname -s)" == "mercury" && "$LOGNAME" == "mike" ]] && command -v chezmoi > /dev/null 2>&1 && [[ -d "$HOME"/.local/share/chezmoi ]]; then
    mapfile -t chezmoi_managed < <(chezmoi managed -p absolute)

    # Look for chezmoi managed files and edit them with chezmoi edit instead of vi
    for arg in "$@"; do
      if [[ "$arg" == "--" ]]; then
        past_flags=true; flags+=("$arg")
      elif ! $past_flags && [[ "$arg" =~ ^[+\-] ]]; then
        flags+=("$arg")
      elif [[ " ${chezmoi_managed[*]} " == *" $(realpath "$arg" 2> /dev/null) "* ]]; then
        chezmoi_files+=("$arg")
      else
        editor_files+=("$arg")
      fi
    done
    exec_dir=$(find_exec_dir)
    if [[ -n "$exec_dir" ]]; then
      chezmoi_editor=$(mktemp "$exec_dir/editor.XXXXXXXXX.sh")
      TMPFILES+=("$chezmoi_editor")
      printf '#!/bin/sh\nexec %s "$@"\n' \
        "$(printf '%q ' "$EDITOR" "${flags[@]}")" > "$chezmoi_editor"
      chmod +x "$chezmoi_editor"
    else
      chezmoi_editor="$EDITOR ${flags[*]}"
    fi
  else
    exec "$EDITOR" "$@"
  fi

  if (( ${#chezmoi_files[@]} > 0 )); then
    echo "Using 'chezmoi edit' for: ${chezmoi_files[@]}"
    EDITOR="$chezmoi_editor" chezmoi edit "${chezmoi_files[@]}"
  fi

  # Edit any other files with nvim or vim
  if (( ${#editor_files[@]} > 0 )); then
    exec "$EDITOR" "${flags[@]}" "${editor_files[@]}"
  elif (( ${#chezmoi_files[@]} == 0 )); then
    exec "$EDITOR" "${flags[@]}"
  fi
fi
