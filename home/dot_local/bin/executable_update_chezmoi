#!/usr/bin/env bash

command -v dpkg > /dev/null 2>&1 || { echo "Error: This program is for Debian/Ubuntu" >&2 ; exit 1 ; }

ARCH=$(dpkg --print-architecture)
# Get download url
url=$(curl -s https://api.github.com/repos/twpayne/chezmoi/releases/latest | \
  awk -F'"' -va="$ARCH" '$0 ~ "\"browser_download_url\": \".*/chezmoi_.*_linux_"a"\\.deb\""{print $4}')

if [[ -z "$url" ]]; then
  echo "Error: Could not determine download url" >&2
  exit 1
fi

trap 'rm -Rf -- "$TMPDIR"' EXIT
trap 'exit 1' INT TERM

TMPDIR=$(mktemp -d)

curl -sLo "$TMPFILE"/chezmoi.deb "$url"
if [[ ! -s "$TMPFILE"/chezmoi.deb ]]; then
  echo "Error: Could not download chezmoi.deb for $ARCH" >&2
  exit 1
fi

sudo dpkg -i "$TMPFILE"/chezmoi.deb

