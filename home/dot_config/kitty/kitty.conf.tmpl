# vim: set filetype=kitty :
font_family               DejaVuSansM Nerd Font Mono
font_size                 10.0
# allow_remote_control      password
background_opacity        0.8
close_on_child_death      yes
confirm_os_window_close   0
clipboard_control write-clipboard write-primary read-clipboard read-primary
cursor_blink_interval     0
cursor_shape              block
cursor_trail              1
cursor_trail_color        #3daee9
cursor_trail_start_threshold 0
enable_audio_bell         no
enabled_layouts           splits, stack, grid
scrollback_lines          10000
shell_integration         no-cursor no-title
visual_bell_color         white
visual_bell_duration      0.1
window_padding_width      2
mouse_map                 left click ungrabbed
mouse_map                 ctrl+left click ungrabbed mouse_handle_click selection link prompt
clear_all_shortcuts       yes

# Global key bindings
map                       ctrl+shift+c             copy_to_clipboard
map                       ctrl+shift+v             paste_from_clipboard
map                       ctrl+shift+r             load_config_file
map                       ctrl+shift+f5            load_config_file
map                       ctrl+shift+f3            command_palette
map                       ctrl+shift+equal         change_font_size all +1.0
map                       ctrl+shift+kp_add        change_font_size all +1.0
map                       ctrl+shift+plus          change_font_size all +1.0
map                       ctrl+shift+minus         change_font_size all -1.0
map                       ctrl+shift+kp_subtract   change_font_size all -1.0
map                       ctrl+shift+up            scroll_line_up
map                       ctrl+shift+down          scroll_line_down
map                       ctrl+(                   scroll_line_up
map                       ctrl+)                   scroll_line_down
map                       ctrl+shift+page_up       scroll_page_up
map                       ctrl+shift+page_down     scroll_page_down
map                       ctrl+{                   scroll_page_up
map                       ctrl+}                   scroll_page_down
map                       ctrl+shift+escape        kitty_shell window
# map                       ctrl+shift+h             show_scrollback
map                       ctrl+shift+/             search_scrollback
map                       ctrl+shift+u             open_url_with_hints

# map                       ctrl+| launch --location=vsplit --cwd=current
# map                       ctrl+} launch --location=hsplit --cwd=current
# map                       ctrl+shift+h neighboring_window left
# map                       ctrl+shift+j neighboring_window down
# map                       ctrl+shift+k neighboring_window up
# map                       ctrl+shift+l neighboring_window right

map                             ctrl+b>shift+j launch --location=hsplit $HOME/.config/kitty/ssh_split.sh -h
map --when-focus-on var:in_tmux ctrl+b>k no-op
map                             ctrl+b>j launch --location=vsplit sh -c 'kitty @ launch --no-response --location=vsplit ssh $(printf "SSH to (vsplit): " >&2; read -r host; [[ -n "$host" ]] && echo "$host" || exit 1)'
map --when-focus-on var:in_tmux ctrl+b>k no-op

## Split Management
# Vertical
map                             ctrl+b>% launch --location=vsplit --cwd=current
map --when-focus-on var:in_tmux ctrl+b>% no-op
map                             ctrl+b>ctrl+% launch --location=vsplit --cwd=current
map --when-focus-on var:in_tmux ctrl+b>ctrl+% no-op
map                             ctrl+b>\ launch --location=vsplit --cwd=current
map --when-focus-on var:in_tmux ctrl+b>\ no-op
map                             ctrl+b>ctrl+\ launch --location=vsplit --cwd=current
map --when-focus-on var:in_tmux ctrl+b>ctrl+\ no-op
map                             ctrl+b>| launch --location=vsplit --cwd=current
map --when-focus-on var:in_tmux ctrl+b>| no-op
map                             ctrl+b>ctrl+| launch --location=vsplit --cwd=current
map --when-focus-on var:in_tmux ctrl+b>ctrl+| no-op
# Horizontal
map                             ctrl+b>quotedbl launch --location=hsplit --cwd=current
map --when-focus-on var:in_tmux ctrl+b>quotedbl no-op
map                             ctrl+b>ctrl+quotedbl launch --location=hsplit --cwd=current
map --when-focus-on var:in_tmux ctrl+b>ctrl+quotedbl no-op
map                             ctrl+b>- launch --location=hsplit --cwd=current
map --when-focus-on var:in_tmux ctrl+b>- no-op
map                             ctrl+b>ctrl+- launch --location=hsplit --cwd=current
map --when-focus-on var:in_tmux ctrl+b>ctrl+- no-op
map                             ctrl+b>_ launch --location=hsplit --cwd=current
map --when-focus-on var:in_tmux ctrl+b>_ no-op
map                             ctrl+b>ctrl+_ launch --location=hsplit --cwd=current
map --when-focus-on var:in_tmux ctrl+b>ctrl+_ no-op

# Split Navigation
map                             ctrl+b>ctrl+h neighboring_window left
map --when-focus-on var:in_tmux ctrl+b>ctrl+h no-op

map                             ctrl+b>ctrl+j neighboring_window down
map --when-focus-on var:in_tmux ctrl+b>ctrl+j no-op

map                             ctrl+b>ctrl+k neighboring_window up
map --when-focus-on var:in_tmux ctrl+b>ctrl+k no-op

map                             ctrl+b>ctrl+l neighboring_window right
map --when-focus-on var:in_tmux ctrl+b>ctrl+l no-op

# Split Management
map                       ctrl+shift+b>r start_resizing_window


# map                       alt+\ launch --location=vsplit --cwd=current
map                       alt+shift+\ launch --location=vsplit --cwd=current
# map                       alt+shift+\ launch --location=vsplit
map                       ctrl+shift+b>\ launch --location=vsplit --cwd=current
map                       ctrl+shift+b>ctrl+shift+\ launch --location=vsplit --cwd=current
map                       ctrl+shift+b>shift+\ launch --location=vsplit

# map                       alt+- launch --location=hsplit --cwd=current
map                       alt+shift+- launch --location=hsplit --cwd=current
# map                       alt+shift+- launch --location=hsplit
map                       ctrl+shift+b>- launch --location=hsplit --cwd=current
map                       ctrl+shift+b>ctrl+shift+- launch --location=hsplit --cwd=current
map                       ctrl+shift+b>shift+- launch --location=hsplit

map                       alt+a neighboring_window left
map                       alt+left neighboring_window left
map                       ctrl+shift+b>h neighboring_window left
map                       ctrl+shift+b>ctrl+shift+h neighboring_window left

map                       alt+s neighboring_window down
map                       alt+down neighboring_window down
map                       ctrl+shift+b>j neighboring_window down

map                       alt+w neighboring_window up
map                       alt+up neighboring_window up
map                       ctrl+shift+b>k neighboring_window up

map                       alt+d neighboring_window right
map                       alt+right neighboring_window right
map                       ctrl+shift+b>l neighboring_window right
map                       ctrl+shift+b>ctrl+shift+l neighboring_window right

map                       alt+shift+a move_window left
map                       alt+shift+left move_window left
map                       ctrl+shift+b>shift+[ move_window left

map                       alt+shift+s move_window down
map                       alt+shift+down move_window down

map                       alt+shift+w move_window up
map                       alt+shift+up move_window up

# map                       alt+shift+j layout_action move_to_screen_edge bottom
# map                       alt+shift+k layout_action move_to_screen_edge top
map                       alt+shift+d move_window right
map                       alt+shift+right move_window right
map                       ctrl+shift+b>shift+] move_window right

map                       alt+z         toggle_layout stack
map                       ctrl+shift+b>z      toggle_layout stack
map                       ctrl+shift+b>ctrl+shift+z toggle_layout stack
map                       ctrl+shift+l  next_layout

map                       alt+shift+ctrl+h resize_window narrower
map                       alt+shift+ctrl+j resize_window shorter
map                       alt+shift+ctrl+k resize_window taller
map                       alt+shift+ctrl+l resize_window wider

# My theme settings
background            #000000
foreground            #eff0f1
cursor                #fcfcfc
selection_background  #3daee9
selection_foreground  #fcfcfc

include $HOME/.config/kitty/{{- .chezmoi.hostname }}.conf
